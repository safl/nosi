#cloud-config
# nosi aidev : Ubuntu 24.04 LTS (noble). The LTS that NVIDIA CUDA /
# NOKM / DOCA, AMD ROCm / amdgpu-install, and Mellanox MLNX_OFED
# qualify against; cijoe/workflows/setup_cudadev.yaml +
# setup_rocmdev.yaml pin to this base. Same baseline as
# sysdev-ubuntu-2404 plus Node.js and a set of agentic-AI command-line
# tools (claude-code, codex, gemini-cli, opencode, pi). Distro RDMA
# user space is included so ibverbs-capable apps work out of the box
# on any vendor. No GPU vendor stack is baked in -- aidev stays
# neutral across x86/nvidia, x86/amd, and CPU-only deployments;
# operators install the vendor driver of their choice post-flash (or
# layer cijoe/workflows/setup_cudadev.yaml / setup_rocmdev.yaml). Same
# default credentials: `odus` / `odus.321`, root locked.
#
# Targets: flashable x86_64 .img.gz AND a WSL2 rootfs tarball derived
# from the same bake by ``wsl_rootfs_publish``
# (kernel/grub/firmware/cloud-init get stripped post-bake).

hostname: nosi-aidev
fqdn: nosi-aidev.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

# Strip the base cloud image's default user (`ubuntu`) before cloud-init's
# users module runs. Two reasons: avoid an unused account in /etc/passwd
# (in the flashable image AND the derived WSL2 tarball), and free UID
# 1000 so odus can claim it (the WSL/Linux convention for the first
# interactive user; lots of tooling assumes UID 1000 = primary operator,
# including wsl-distribution.conf's defaultUid default).
bootcmd:
  - userdel -r ubuntu 2>/dev/null || true

# Operator account: `odus` with password `odus.321`, passwordless sudo,
# pinned to UID 1000. Created here (cloud-init users-module) rather than
# in runcmd because users-module calls `useradd -p HASH`, which writes
# the hash straight to /etc/shadow without going through PAM (so
# pam_pwquality cannot reject `odus.321` for containing the username),
# without depending on `openssl` being installed at runcmd time, and
# without the runcmd hazard that a single non-zero exit silently skips
# later items. Hash is `openssl passwd -6 -salt nosiOpRator odus.321`;
# salt is fixed so identical bakes produce identical /etc/shadow.
# `- default` is intentionally absent (bootcmd above removes the base
# `ubuntu` user). render+video on top of sysdev's sudo+kvm so odus can
# drive a GPU /dev/dri device without sudo once the operator installs a
# vendor stack. Root is locked in runcmd below. The default password
# stays active out of the box so CI jobs can flash and ssh straight in;
# step 29 just marks the system as on the default and the motd warns at
# every interactive login until the operator rotates with `passwd odus`.
# On WSL, step 29 also offers an interactive `passwd` prompt on the
# first non-root TTY shell (silent for `wsl exec`-style automation).
# Operators who want a personal identity rename odus rather than create
# a second account (see provision/README.md).
users:
  - name: odus
    uid: 1000
    gecos: nosi operator
    shell: /bin/bash
    groups: [sudo, kvm, render, video]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: "$6$nosiOpRator$MNNihj4cU2CANkmlcYthq7Fa.U2r5VwwJxtm1TlqmznXizzkddi0sxKc3YnkgRpcvOLc2V7nOGpbp/tOyD5M81"

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

package_update: true
package_upgrade: true

packages:
  # --- baseline sysdev set (mirrors cloudinit-sysdev-ubuntu-2404.user) ---------
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  # NTP via systemd's own daemon. See cloudinit-sysdev-debian-13.user for rationale.
  - systemd-timesyncd
  - bash-completion      # autoloads /etc/bash_completion.d/* on interactive bash
  - btop
  - direnv               # per-directory env vars; bash hook in /etc/profile.d
  - fd-find              # /usr/bin/fdfind; symlinked to fd in runcmd
  - fzf
  - gh                   # GitHub CLI
  - git
  - git-delta            # `delta` pager, wired into /etc/gitconfig
  - htop
  - just                 # task runner (sister to make-as-task-runner)
  - meson
  - ninja-build
  - parallel             # GNU parallel
  - ripgrep
  - stress-ng            # CPU / memory stress for thermals + bench
  - sysstat              # iostat / sar / mpstat
  - time                 # GNU time (verbose vs the bash builtin)
  - linux-headers-generic # DKMS needs the running kernel's headers; noble
                         # ships GA 6.8 which CUDA / NOKM / ROCm / MLNX_OFED
                         # all qualify against (HWE must NOT be installed)
  - linux-tools-generic  # perf + bpftool
  - linux-tools-common
  - shellcheck           # bash linter; complements bash-language-server below
  - unzip                # yazi ships as a zip in its releases
  - libicu-dev           # ICU runtime for marksman (.NET-based markdown LSP);
                         # without it dotnet aborts with "Couldn't find a valid
                         # ICU package" and step 20 fails fast on marksman
  - fontconfig           # fc-cache for the JetBrainsMono Nerd Font install
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - network-manager       # provides nmtui (inert on WSL after strip)
  - nmap
  - strace
  - tcpdump
  - wget
  - build-essential
  - ccache               # transparent compiler cache; wraps gcc/clang
  - clang
  - clang-tools
  - clangd
  - cmake                # ubiquitous C/C++ build orchestrator
  - cppcheck             # standalone C/C++ static analyzer
  - gdb
  - lldb                 # helix DAP debugger backend (lldb-dap binary)
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt
  - podman
  - podman-docker
  - skopeo
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  - linux-firmware
  # CPU microcode (early-load via initramfs). See cloudinit-sysdev-ubuntu-2404.user for
  # rationale; same multiverse-+-main + N97 / Ryzen 5 motivation.
  - intel-microcode
  - amd64-microcode
  - ovmf
  - qemu-system-x86
  - qemu-utils
  # --- aidev additions ---------------------------------------------------
  # nodejs + npm are NOT listed here for noble: the universe nodejs is
  # 18.x (upstream EOL 2025-04), and the agentic CLIs in step
  # 41-npm-globals (claude-code, codex, gemini-cli, opencode) reject
  # Node 18 with engines.node constraints. Node 22 LTS comes from the
  # NodeSource apt repo set up in runcmd below, before apply.sh runs.
  # Mellanox user space: distro-shipped RDMA stack. Enough for ibverbs apps
  # and basic InfiniBand/RoCE bring-up; MLNX_OFED proper is opt-in via the
  # DOCA repo (operator can add it post-flash if they need kernel-tied
  # functionality, or via the cijoe/workflows/setup_cudadev.yaml MLNX_OFED
  # install step which targets exactly this base).
  - rdma-core
  - libibverbs1
  - libmlx5-1
  - ibverbs-utils
  - infiniband-diags
  - perftest

# Drop the nosi provision/ tree into /opt/nosi/provision/. The
# __NOSI_PROVISION_FILES__ marker is expanded at bake time by
# cijoe/scripts/userdata_render.py: it replaces this comment with one
# write_files: entry per file under provision/ (apply.sh, lib/*,
# steps/*), chmod 0755. The runcmd: section below then invokes
# /opt/nosi/provision/apply.sh, which is also the same script
# operators run on a vanilla Hetzner VM to reach image parity.
write_files:
  # __NOSI_PROVISION_FILES__

runcmd:

  # Node 22 LTS via NodeSource. Has to happen before apply.sh runs
  # step 41-npm-globals: noble's universe nodejs is 18.x (upstream EOL
  # 2025-04) which the agentic CLIs refuse to install on. setup_22.x
  # writes /etc/apt/sources.list.d/nodesource.list + the signing key,
  # then `apt-get install nodejs` pulls Node 22 + npm 10. set -e here
  # so a NodeSource fetch failure aborts cloud-init immediately rather
  # than letting apply.sh limp into step 41 against a missing nodejs.
  - |
    set -e
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs

  # nosi provision: r8125 DKMS + softdep, clock-from-http + NTP enable,
  # nosi-motd renderer + service, nosi-firstboot-inventory + service.
  # Each step under provision/steps/ is independently idempotent and
  # cross-distro where it makes sense. Same apply.sh runs on a vanilla
  # Hetzner VM (`sudo /opt/nosi/provision/apply.sh ubuntu-2404-aidev`) to
  # reach this image's parity.
  - /opt/nosi/provision/apply.sh ubuntu-2404-aidev

  # odus itself is created by the top-level `users:` block (hashed_passwd
  # written straight to /etc/shadow, plus render+video groups for the GPU
  # user space stack). All that's left here is locking root so the only
  # login channel is odus.
  - passwd -l root

  - rm -f /etc/ssh/ssh_host_*
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - cloud-init clean --logs --seed || true

  - |
    set -eu
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  # Clock floor: see cloudinit-sysdev-debian-13.user for rationale. Touch /usr/lib/clock-epoch
  # last so PID-1 systemd uses the bake mtime as the boot-time clock floor.
  # Inert under WSL (Windows host sets the clock).
  - touch /usr/lib/clock-epoch

  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi ubuntu-2404-aidev baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
