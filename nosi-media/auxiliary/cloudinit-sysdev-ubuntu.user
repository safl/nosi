#cloud-config
# nosi base : Ubuntu 26.04 LTS (resolute). Default credentials: operator
# account `odus` with password `odus.321`, root locked, SSH password auth on.
# Per-instance SSH identity: host keys stripped at end of cloud-init,
# regenerated on first boot.

hostname: nosi-ubuntu
fqdn: nosi-ubuntu.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# Ubuntu cloud images already include universe in their default sources,
# so btop / podman-docker resolve without extra config. (helix + zellij
# are pulled from upstream tarballs in runcmd; the universe packages
# either lag the upstream releases or, in 26.04, vanished entirely.)

# Drop Install-Recommends to keep the image lean -- our explicit packages:
# list already names everything we want, and Recommends were inflating
# the gz by GBs on debian/ubuntu compared to fedora's weak-deps default.
apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

# See debian variant: upgrade the base snapshot before installing our
# explicit packages, so the baked image picks up upstream security fixes.
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  - btop
  - direnv               # per-directory env vars; bash hook in /etc/profile.d
  - fd-find              # /usr/bin/fdfind; symlinked to fd in runcmd
  - fzf
  - gh                   # GitHub CLI
  - git
  - git-delta            # `delta` pager, wired into /etc/gitconfig
  - htop
  - just                 # task runner (sister to make-as-task-runner)
  - meson
  - ninja-build
  - ripgrep
  - shellcheck           # bash linter; sysdev's substitute for the
                         # Node-based bash-language-server (aidev only)
  - unzip                # yazi ships as a zip in its releases
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - network-manager       # provides nmtui for interactive interface config
  - nmap
  - strace
  - tcpdump
  - wget
  - build-essential
  - clang
  - clang-tools          # clang-format, clang-tidy
  - clangd               # C/C++ LSP
  - gdb
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  # See debian variant: name podman's Recommends explicitly (crun /
  # fuse-overlayfs / dbus-user-session) since Recommends are off.
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt
  - podman
  - podman-docker
  - skopeo
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  # firmware for bare-metal targets flashed via bty: i915 GuC/HuC, iwlwifi,
  # regulatory.db, etc. The kernel package used to pull linux-firmware via
  # Recommends; we drop Recommends so name it explicitly.
  - linux-firmware
  - ovmf
  - qemu-system-x86
  - qemu-utils

runcmd:
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "nosi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version

  # Install Rust via rustup (system-wide, default stable toolchain + the
  # rust-analyzer LSP component). Same philosophy as the uv install above:
  # pull a current upstream toolchain rather than a distro package.
  - |
    set -eu
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile default
    /usr/local/cargo/bin/rustup component add rust-analyzer
    cat > /etc/profile.d/nosi-rust.sh <<'PROF'
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    case ":$PATH:" in
        *":/usr/local/cargo/bin:"*) : ;;
        *) export PATH="/usr/local/cargo/bin:$PATH" ;;
    esac
    PROF
    chmod 0644 /etc/profile.d/nosi-rust.sh
    /usr/local/cargo/bin/rustc --version

  # Install Helix editor from upstream release (see debian variant for
  # rationale). Runtime data lives at /usr/local/share/helix/runtime,
  # located via $HELIX_RUNTIME (set in /etc/profile.d/nosi-helix.sh).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64-linux ;;
        aarch64) tarch=aarch64-linux ;;
        *) echo "nosi: unsupported arch $arch for helix" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/helix-editor/helix/releases/latest \
        | sed 's#.*/tag/##')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/helix-editor/helix/releases/download/${ver}/helix-${ver}-${tarch}.tar.xz" \
        | tar -xJ -C "$tmp"
    src="$tmp/helix-${ver}-${tarch}"
    install -D -m 0755 "$src/hx" /usr/local/bin/hx
    mkdir -p /usr/local/share/helix
    rm -rf /usr/local/share/helix/runtime
    cp -a "$src/runtime" /usr/local/share/helix/runtime
    rm -rf "$tmp"
    cat > /etc/profile.d/nosi-helix.sh <<'PROF'
    export HELIX_RUNTIME=/usr/local/share/helix/runtime
    PROF
    chmod 0644 /etc/profile.d/nosi-helix.sh
    /usr/local/bin/hx --version

  # Install Zellij from upstream release (single static binary, musl).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  ztarget=x86_64-unknown-linux-musl ;;
        aarch64) ztarget=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for zellij" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/zellij-org/zellij/releases/latest/download/zellij-${ztarget}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/zellij"
    rm -rf "$tmp"
    /usr/local/bin/zellij --version

  # Install lazygit from upstream release (see debian variant for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  larch=Linux_x86_64 ;;
        aarch64) larch=Linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for lazygit" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/jesseduffield/lazygit/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/v${ver}/lazygit_${ver}_${larch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/lazygit"
    rm -rf "$tmp"
    /usr/local/bin/lazygit --version

  # Install yazi from upstream release (see debian variant for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  yarch=x86_64-unknown-linux-musl ;;
        aarch64) yarch=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for yazi" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL -o "$tmp/yazi.zip" \
        "https://github.com/sxyazi/yazi/releases/latest/download/yazi-${yarch}.zip"
    unzip -q -d "$tmp" "$tmp/yazi.zip"
    install -m 0755 -t /usr/local/bin \
        "$tmp/yazi-${yarch}/yazi" \
        "$tmp/yazi-${yarch}/ya"
    rm -rf "$tmp"
    /usr/local/bin/yazi --version

  # Install taplo (TOML LSP) from upstream release (see debian variant).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64 ;;
        aarch64) tarch=aarch64 ;;
        *) echo "nosi: unsupported arch $arch for taplo" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/tamasfe/taplo/releases/latest/download/taplo-full-linux-${tarch}.gz" \
        | gunzip > /usr/local/bin/taplo
    chmod 0755 /usr/local/bin/taplo
    /usr/local/bin/taplo --version

  # Install marksman (Markdown LSP) from upstream release (see debian variant).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  march=x64 ;;
        aarch64) march=arm64 ;;
        *) echo "nosi: unsupported arch $arch for marksman" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/artempyanykh/marksman/releases/latest/download/marksman-linux-${march}" \
        -o /usr/local/bin/marksman
    chmod 0755 /usr/local/bin/marksman
    /usr/local/bin/marksman --version 2>/dev/null \
        || /usr/local/bin/marksman --help >/dev/null

  # Install oras from upstream release (see debian variant for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  oarch=linux_amd64 ;;
        aarch64) oarch=linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for oras" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/oras-project/oras/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/oras-project/oras/releases/download/v${ver}/oras_${ver}_${oarch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/oras"
    rm -rf "$tmp"
    /usr/local/bin/oras version

  # fd symlink + system-wide delta-as-git-pager. See debian variant.
  - |
    set -eu
    if [ -x /usr/bin/fdfind ] && [ ! -e /usr/local/bin/fd ]; then
        ln -s /usr/bin/fdfind /usr/local/bin/fd
    fi
    cat > /etc/gitconfig <<'GITCONF'
    # nosi: system-wide git defaults.
    [core]
        pager = delta
    [interactive]
        diffFilter = delta --color-only
    [delta]
        navigate = true
        line-numbers = true
    [merge]
        conflictstyle = zdiff3
    GITCONF
    chmod 0644 /etc/gitconfig

  # Shared /opt/python-tools venv (see debian variant for rationale):
  # ruff + pyright LSPs + devbind + hugepages + iommu.
  - |
    set -eu
    python3 -m venv /opt/python-tools
    /opt/python-tools/bin/pip install --no-cache-dir --upgrade pip
    /opt/python-tools/bin/pip install --no-cache-dir ruff pyright devbind hugepages iommu
    for bin in ruff pyright pyright-langserver devbind hugepages iommu; do
        ln -sf /opt/python-tools/bin/$bin /usr/local/bin/$bin
    done
    ruff --version
    pyright --version
    devbind --help >/dev/null 2>&1 || true
    hugepages --help >/dev/null 2>&1 || true
    iommu --help >/dev/null 2>&1 || true

  - |
    cat > /etc/profile.d/nosi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-localbin.sh

  # direnv bash hook (see debian variant for rationale).
  - |
    cat > /etc/profile.d/nosi-direnv.sh <<'PROF'
    if command -v direnv >/dev/null 2>&1; then
        eval "$(direnv hook bash)"
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-direnv.sh

  - mkdir -p /etc/containers && touch /etc/containers/nodocker
  - systemctl enable podman.socket

  # Userspace PCI prerequisites (see debian variant for full rationale):
  # preload vfio-pci + uio_pci_generic, hand /dev/vfio/* to the kvm group
  # so passthrough works without sudo, enable IOMMU on the kernel cmdline.
  - |
    cat > /etc/modules-load.d/nosi-userspace-pci.conf <<'MODS'
    vfio-pci
    uio_pci_generic
    MODS
    cat > /etc/udev/rules.d/99-nosi-vfio.rules <<'RULES'
    SUBSYSTEM=="vfio", OWNER="root", GROUP="kvm", MODE="0660"
    RULES
  - |
    set -eu
    EXTRA="intel_iommu=on amd_iommu=on iommu=pt"
    if grep -q '^GRUB_CMDLINE_LINUX=' /etc/default/grub; then
        for arg in $EXTRA; do
            if ! grep -q "GRUB_CMDLINE_LINUX=.*\\b${arg}\\b" /etc/default/grub; then
                sed -i "s/^GRUB_CMDLINE_LINUX=\"\(.*\)\"$/GRUB_CMDLINE_LINUX=\"\1 ${arg}\"/" /etc/default/grub
            fi
        done
    else
        printf '\nGRUB_CMDLINE_LINUX="%s"\n' "$EXTRA" >> /etc/default/grub
    fi
    update-grub

  # /etc/motd banner regenerated each boot by nosi-motd.service.
  # (See debian variant for the full script + service body.)
  - |
    cat > /usr/local/bin/nosi-motd <<'SCRIPT'
    #!/bin/sh
    set -eu

    . /etc/os-release 2>/dev/null || true
    distro="${PRETTY_NAME:-Linux}"
    kernel="$(uname -r)"
    arch="$(uname -m)"
    host="$(hostnamectl --static 2>/dev/null || hostname)"

    ips=""
    while IFS= read -r line; do
        iface="$(echo "$line" | awk '{print $2}')"
        addr="$(echo "$line" | awk '{print $4}' | cut -d/ -f1)"
        [ -z "$addr" ] && continue
        ips="${ips}${ips:+, }${addr} (${iface})"
    done <<EOF
    $(ip -4 -o addr show scope global 2>/dev/null)
    EOF
    [ -z "$ips" ] && ips="(none)"

    iommu="$(iommu show 2>/dev/null | awk '/^mode:/ {print $2}')"
    [ -z "$iommu" ] && iommu="unset"

    hp_count="$(awk '/HugePages_Total:/ {print $2}' /proc/meminfo)"
    hp_size_kb="$(awk '/Hugepagesize:/ {print $2}' /proc/meminfo)"
    if [ "${hp_count:-0}" -gt 0 ]; then
        hp_mib=$(( hp_count * hp_size_kb / 1024 ))
        hugepgs="${hp_count} x ${hp_size_kb} kB = ${hp_mib} MiB"
    else
        hugepgs="0 (use 'hugepages' to allocate)"
    fi

    cpu_model="$(awk -F': ' '/^model name/ {print $2; exit}' /proc/cpuinfo)"
    cpu_count="$(nproc)"
    ram_kib="$(awk '/MemTotal:/ {print $2}' /proc/meminfo)"
    ram_gib=$(( ram_kib / 1024 / 1024 ))
    nvme_count="$(find /dev -maxdepth 1 -name 'nvme*n*' 2>/dev/null | wc -l)"

    cat <<EOM

      nosi sysdev   ${distro}   Linux ${kernel}   ${arch}

      hostname:  ${host}
      ip:        ${ips}
      iommu:     ${iommu}
      hugepgs:   ${hugepgs}
      cpu:       ${cpu_model} x ${cpu_count}
      ram:       ${ram_gib} GiB
      nvme:      ${nvme_count}

      Tools:     rg fd fzf lazygit delta yazi oras gh just direnv
      Helpers:
        iommu {show|off-for-uio|off-for-vfio|strict|pt}   IOMMU substrate (reboot to apply)
        devbind                                           bind/unbind PCI device to a driver
        hugepages                                         inspect / reserve hugepages

    EOM
    SCRIPT
    chmod 0755 /usr/local/bin/nosi-motd

    cat > /etc/systemd/system/nosi-motd.service <<'UNIT'
    [Unit]
    Description=Generate nosi banner for /etc/motd
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=oneshot
    ExecStart=/bin/sh -c '/usr/local/bin/nosi-motd > /etc/motd'
    RemainAfterExit=yes

    [Install]
    WantedBy=multi-user.target
    UNIT
  - systemctl enable nosi-motd.service

  - passwd -l root
  - useradd --create-home --shell /bin/bash --groups sudo,kvm odus
  # See fedora variant: pre-hash and use chpasswd -e so PAM's
  # pam_pwquality cannot silently reject the password.
  - |
    set -eu
    hash=$(openssl passwd -6 'odus.321')
    printf 'odus:%s\n' "$hash" | chpasswd -e
  - |
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  # Drop snapd. Ubuntu cloud images ship it preinstalled; sysdev doesn't
  # use snaps (apt + podman cover the same ground) and snapd's
  # auto-refresh timer + squashfs loop mounts add measurable runtime
  # overhead on a flashed bare-metal box. Remove installed snaps first so
  # apt can unmount their loops, then purge snapd and hold it so a future
  # package_upgrade can't drag it back via a Recommends/Depends.
  - |
    set -eu
    if command -v snap >/dev/null 2>&1; then
        # Iterate a few times: some snaps refuse removal until their
        # dependents go (e.g. core / snapd base is last).
        for _ in 1 2 3; do
            snaps=$(snap list 2>/dev/null | awk 'NR>1 {print $1}') || true
            [ -z "$snaps" ] && break
            for s in $snaps; do
                snap remove --purge "$s" 2>/dev/null || true
            done
        done
    fi
    if dpkg-query -W -f='${Status}' snapd 2>/dev/null \
            | grep -q "install ok installed"; then
        DEBIAN_FRONTEND=noninteractive apt-get -y purge snapd
    fi
    apt-mark hold snapd 2>/dev/null || true
    rm -rf /root/snap /home/*/snap /snap /var/snap /var/lib/snapd /var/cache/snapd

  # Minimize background daemons / timers (see debian variant for rationale).
  - |
    set -eu
    # See debian variant for rationale. Purges desktop-flavored daemons
    # the cloud base may carry but a headless sysdev box doesn't want.
    to_purge=""
    # Beyond the cross-distro set, Ubuntu carries Canonical-specific
    # phone-home / interactive-prompt daemons (apport, whoopsie, pollinate,
    # update-notifier-common, ubuntu-pro-client). needrestart prompts at
    # apt time; we don't run apt interactively. accountsservice is the
    # desktop user-metadata D-Bus daemon, unused headless.
    for pkg in unattended-upgrades modemmanager packagekit packagekit-tools \
               udisks2 accountsservice \
               apport whoopsie pollinate needrestart \
               update-notifier-common \
               ubuntu-pro-client ubuntu-advantage-tools; do
        if dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null \
                | grep -q "install ok installed"; then
            to_purge="$to_purge $pkg"
        fi
    done
    if [ -n "$to_purge" ]; then
        DEBIAN_FRONTEND=noninteractive apt-get -y purge $to_purge
    fi
    apt-get -y autoremove --purge || true
    systemctl mask \
        apt-daily.service apt-daily.timer \
        apt-daily-upgrade.service apt-daily-upgrade.timer \
        fwupd.service fwupd-refresh.service fwupd-refresh.timer \
        motd-news.service motd-news.timer \
        man-db.service man-db.timer \
        e2scrub_all.service e2scrub_all.timer e2scrub_reap.service \
        polkit.service \
        smartd.service \
        multipathd.service multipathd.socket \
        networkd-dispatcher.service \
        2>/dev/null || true

  - rm -f /etc/ssh/ssh_host_*
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - cloud-init clean --logs --seed || true

  # Deep cleanup (see debian variant for rationale).
  - |
    set -eu
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi ubuntu-sysdev baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
