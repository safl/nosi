#cloud-config
# nosi wsl : Ubuntu 26.04 LTS (resolute) WSL2 rootfs. Headless baseline
# (same as cloudinit-headless-ubuntu-2604.user) plus a small set of GUI
# dev tools (meld / gitk / git-gui) that render through WSLg without a
# compositor inside the rootfs. wsl_rootfs_publish strips
# kernel/grub/firmware/cloud-init post-bake; the .tar.gz gets imported
# via `wsl --import`. Default credentials: operator account `odus`
# with password `odus.321`, root locked.

hostname: nosi-ubuntu-wsl
fqdn: nosi-ubuntu-wsl.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

# Strip the base cloud image's default user (`ubuntu`) so UID 1000 is
# free for odus. Required for WSL: lots of tooling assumes UID 1000 =
# primary operator, and wsl-distribution.conf's defaultUid defaults
# to 1000.
bootcmd:
  - userdel -r ubuntu 2>/dev/null || true

users:
  - name: odus
    uid: 1000
    gecos: nosi operator
    shell: /bin/bash
    groups: [sudo, kvm]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: "$6$nosiOpRator$MNNihj4cU2CANkmlcYthq7Fa.U2r5VwwJxtm1TlqmznXizzkddi0sxKc3YnkgRpcvOLc2V7nOGpbp/tOyD5M81"

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

package_update: true
package_upgrade: true

packages:
  # --- headless baseline (mirrors cloudinit-headless-ubuntu-2604.user) -
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  - systemd-timesyncd
  - bash-completion
  - btop
  - direnv
  - fd-find
  - fzf
  - gh
  - git
  - git-delta
  - htop
  - just
  - meson
  - ninja-build
  - parallel
  - ripgrep
  - shellcheck
  - stress-ng
  - sysstat
  - time
  - unzip
  - libicu-dev
  - linux-headers-generic
  - linux-tools-generic
  - linux-tools-common
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - network-manager
  - nmap
  - strace
  - tcpdump
  - wget
  - build-essential
  - ccache
  - clang
  - clang-tools
  - clangd
  - cmake
  - cppcheck
  - gdb
  - lldb
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt
  - podman
  - podman-docker
  - skopeo
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  - linux-firmware
  - intel-microcode
  - amd64-microcode
  - ovmf
  - qemu-system-x86
  - qemu-utils
  # --- wsl additions ----------------------------------------------------
  # GUI dev tools that render via WSLg (Windows-side Wayland + XWayland
  # server). No compositor inside the rootfs needed: launching `meld` or
  # `gitk` from WSL produces a native Windows window. xdg-utils for
  # xdg-open handlers (clicking a URL inside the WSL distro opens the
  # Windows-side default browser via WSLg's interop layer).
  - meld
  - gitk
  - git-gui
  - xdg-utils

# Drop the nosi provision/ tree into /opt/nosi/provision/. The
# __NOSI_PROVISION_FILES__ marker is expanded at bake time by
# cijoe/scripts/userdata_render.py.
write_files:
  # __NOSI_PROVISION_FILES__

runcmd:

  # Same apply.sh runs on a vanilla Ubuntu 26.04 WSL distro
  # (`sudo /opt/nosi/provision/apply.sh ubuntu-2604-wsl`) to reach this
  # image's parity.
  - /opt/nosi/provision/apply.sh ubuntu-2604-wsl

  - passwd -l root

  - rm -f /etc/ssh/ssh_host_*
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - cloud-init clean --logs --seed || true

  - |
    set -eu
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  # Clock floor: inert under WSL (Windows host sets the clock) but kept
  # for parity with headless variants in case the .img.gz from this bake
  # ever gets flashed to bare metal.
  - touch /usr/lib/clock-epoch

  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi ubuntu-2604-wsl baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
