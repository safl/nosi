#cloud-config
# nosi base : Fedora 44. Default credentials: operator account `odus` with
# password `odus`, root locked, SSH password auth on. Per-instance SSH
# identity: host keys stripped at end of cloud-init, regenerated on first
# boot.

hostname: nosi-fedora
fqdn: nosi-fedora.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  - btop
  - git
  - helix
  - htop
  - meson
  - ninja-build
  - zellij
  - bind-utils
  - curl
  - jq
  - lsof
  - mtr
  - nmap
  - strace
  - tcpdump
  - wget
  - clang
  - gcc
  - gcc-c++
  - gdb
  - make
  - pipx
  - pkgconf-pkg-config
  - python3
  - buildah
  - podman
  - podman-docker
  - skopeo
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  - edk2-ovmf
  - qemu-img
  - qemu-system-x86-core

runcmd:
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "nosi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version

  - |
    cat > /etc/profile.d/nosi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-localbin.sh

  - mkdir -p /etc/containers && touch /etc/containers/nodocker
  - systemctl enable podman.socket

  # Fedora's sshd_config defaults to PasswordAuthentication=no; flip on
  # so the baked `odus:odus` works without an SSH key.
  - |
    printf 'PasswordAuthentication yes\nPermitRootLogin no\n' \
        > /etc/ssh/sshd_config.d/00-nosi.conf
    chmod 0644 /etc/ssh/sshd_config.d/00-nosi.conf

  - passwd -l root
  - useradd --create-home --shell /bin/bash --groups wheel odus
  - echo 'odus:odus' | chpasswd
  - |
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  - rm -f /etc/ssh/ssh_host_*
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - cloud-init clean --logs --seed || true

  - dnf clean all
  - rm -rf /var/cache/dnf/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi fedora-base baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
