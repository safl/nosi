#cloud-config
# nosi aidev : Ubuntu 26.04 LTS (resolute). Same baseline as sysdev-ubuntu
# plus Node.js and a set of agentic-AI command-line tools (claude-code,
# codex, gemini-cli, opencode, pi). Distro RDMA userspace is included so
# ibverbs-capable apps work out of the box on any vendor. No GPU vendor
# stack is baked in -- aidev stays neutral across x86/nvidia, x86/amd,
# and CPU-only deployments; operators install the vendor driver of their
# choice post-flash. Same default credentials: `odus` / `odus.321`, root
# locked.
#
# Targets: flashable x86_64 .img.gz AND a WSL2 rootfs tarball derived from
# the same bake by ``wsl_rootfs_publish`` (kernel/grub/firmware/cloud-init
# get stripped post-bake).

hostname: nosi-aidev
fqdn: nosi-aidev.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

package_update: true
package_upgrade: true

packages:
  # --- baseline sysdev set (mirrors cloudinit-sysdev-ubuntu.user) ---------
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  - btop
  - direnv               # per-directory env vars; bash hook in /etc/profile.d
  - fd-find              # /usr/bin/fdfind; symlinked to fd in runcmd
  - fzf
  - gh                   # GitHub CLI
  - git
  - git-delta            # `delta` pager, wired into /etc/gitconfig
  - htop
  - just                 # task runner (sister to make-as-task-runner)
  - meson
  - ninja-build
  - ripgrep
  - shellcheck           # bash linter; complements bash-language-server below
  - unzip                # yazi ships as a zip in its releases
  - fontconfig           # fc-cache for the JetBrainsMono Nerd Font install
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - network-manager       # provides nmtui (inert on WSL after strip)
  - nmap
  - strace
  - tcpdump
  - wget
  - build-essential
  - clang
  - clang-tools
  - clangd
  - gdb
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt
  - podman
  - podman-docker
  - skopeo
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  - linux-firmware
  - ovmf
  - qemu-system-x86
  - qemu-utils
  # --- aidev additions ---------------------------------------------------
  # Node for the agentic CLIs (npm-globally installed in runcmd below).
  # Ubuntu 26.04 ships Node 22.x in main, which is current enough for the
  # CLIs we install; if a vendor pushes a newer minimum we can fall back to
  # NodeSource. Including npm explicitly since Install-Recommends is off.
  - nodejs
  - npm
  # Mellanox userspace: distro-shipped RDMA stack. Enough for ibverbs apps
  # and basic InfiniBand/RoCE bring-up; MLNX_OFED proper is opt-in via the
  # DOCA repo (operator can add it post-flash if they need kernel-tied
  # functionality).
  - rdma-core
  - libibverbs1
  - libmlx5-1
  - ibverbs-utils
  - infiniband-diags
  - perftest

runcmd:
  # --- uv, rust, helix, zellij, python-tools : copied verbatim from sysdev
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "nosi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version

  - |
    set -eu
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile default
    /usr/local/cargo/bin/rustup component add rust-analyzer
    cat > /etc/profile.d/nosi-rust.sh <<'PROF'
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    case ":$PATH:" in
        *":/usr/local/cargo/bin:"*) : ;;
        *) export PATH="/usr/local/cargo/bin:$PATH" ;;
    esac
    PROF
    chmod 0644 /etc/profile.d/nosi-rust.sh
    /usr/local/cargo/bin/rustc --version

  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64-linux ;;
        aarch64) tarch=aarch64-linux ;;
        *) echo "nosi: unsupported arch $arch for helix" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/helix-editor/helix/releases/latest \
        | sed 's#.*/tag/##')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/helix-editor/helix/releases/download/${ver}/helix-${ver}-${tarch}.tar.xz" \
        | tar -xJ -C "$tmp"
    src="$tmp/helix-${ver}-${tarch}"
    install -D -m 0755 "$src/hx" /usr/local/bin/hx
    mkdir -p /usr/local/share/helix
    rm -rf /usr/local/share/helix/runtime
    cp -a "$src/runtime" /usr/local/share/helix/runtime
    rm -rf "$tmp"
    cat > /etc/profile.d/nosi-helix.sh <<'PROF'
    export HELIX_RUNTIME=/usr/local/share/helix/runtime
    PROF
    chmod 0644 /etc/profile.d/nosi-helix.sh
    /usr/local/bin/hx --version

  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  ztarget=x86_64-unknown-linux-musl ;;
        aarch64) ztarget=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for zellij" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/zellij-org/zellij/releases/latest/download/zellij-${ztarget}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/zellij"
    rm -rf "$tmp"
    /usr/local/bin/zellij --version

  # Install lazygit from upstream release (see debian sysdev for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  larch=Linux_x86_64 ;;
        aarch64) larch=Linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for lazygit" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/jesseduffield/lazygit/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/v${ver}/lazygit_${ver}_${larch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/lazygit"
    rm -rf "$tmp"
    /usr/local/bin/lazygit --version

  # Install yazi from upstream release (see debian sysdev for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  yarch=x86_64-unknown-linux-musl ;;
        aarch64) yarch=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for yazi" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL -o "$tmp/yazi.zip" \
        "https://github.com/sxyazi/yazi/releases/latest/download/yazi-${yarch}.zip"
    unzip -q -d "$tmp" "$tmp/yazi.zip"
    install -m 0755 -t /usr/local/bin \
        "$tmp/yazi-${yarch}/yazi" \
        "$tmp/yazi-${yarch}/ya"
    rm -rf "$tmp"
    /usr/local/bin/yazi --version

  # Install taplo (TOML LSP) from upstream release (see debian sysdev).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64 ;;
        aarch64) tarch=aarch64 ;;
        *) echo "nosi: unsupported arch $arch for taplo" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/tamasfe/taplo/releases/latest/download/taplo-full-linux-${tarch}.gz" \
        | gunzip > /usr/local/bin/taplo
    chmod 0755 /usr/local/bin/taplo
    /usr/local/bin/taplo --version

  # Install marksman (Markdown LSP) from upstream release (see debian sysdev).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  march=x64 ;;
        aarch64) march=arm64 ;;
        *) echo "nosi: unsupported arch $arch for marksman" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/artempyanykh/marksman/releases/latest/download/marksman-linux-${march}" \
        -o /usr/local/bin/marksman
    chmod 0755 /usr/local/bin/marksman
    /usr/local/bin/marksman --version 2>/dev/null \
        || /usr/local/bin/marksman --help >/dev/null

  # Install oras from upstream release (see debian sysdev for rationale).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  oarch=linux_amd64 ;;
        aarch64) oarch=linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for oras" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/oras-project/oras/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/oras-project/oras/releases/download/v${ver}/oras_${ver}_${oarch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/oras"
    rm -rf "$tmp"
    /usr/local/bin/oras version

  # fd symlink + system-wide delta-as-git-pager. See debian sysdev variant.
  - |
    set -eu
    if [ -x /usr/bin/fdfind ] && [ ! -e /usr/local/bin/fd ]; then
        ln -s /usr/bin/fdfind /usr/local/bin/fd
    fi
    cat > /etc/gitconfig <<'GITCONF'
    # nosi: system-wide git defaults.
    [core]
        pager = delta
    [interactive]
        diffFilter = delta --color-only
    [delta]
        navigate = true
        line-numbers = true
    [merge]
        conflictstyle = zdiff3
    GITCONF
    chmod 0644 /etc/gitconfig

  # Install JetBrainsMono Nerd Font system-wide. The font itself only
  # matters for rendering paths that exist on the box: X/Wayland apps
  # (e.g. wslg on WSL2), the framebuffer console with a tool that loads
  # OTF, or X-forwarded SSH. SSH-only operators get no benefit from the
  # font being on the server -- their local terminal does the rendering.
  # We ship it on aidev because WSL is a primary target and wslg is the
  # most likely rendering path.
  - |
    set -eu
    dest=/usr/local/share/fonts/JetBrainsMonoNerdFont
    mkdir -p "$dest"
    curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz \
        | tar -xJ -C "$dest"
    fc-cache -f >/dev/null 2>&1 || true
    fc-list 2>/dev/null | grep -i 'JetBrainsMono Nerd' | head -n1 || true

  - |
    set -eu
    python3 -m venv /opt/python-tools
    /opt/python-tools/bin/pip install --no-cache-dir --upgrade pip
    /opt/python-tools/bin/pip install --no-cache-dir ruff pyright devbind hugepages
    for bin in ruff pyright pyright-langserver devbind hugepages; do
        ln -sf /opt/python-tools/bin/$bin /usr/local/bin/$bin
    done
    ruff --version
    pyright --version

  - |
    cat > /etc/profile.d/nosi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-localbin.sh

  # direnv bash hook (see debian sysdev for rationale).
  - |
    cat > /etc/profile.d/nosi-direnv.sh <<'PROF'
    if command -v direnv >/dev/null 2>&1; then
        eval "$(direnv hook bash)"
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-direnv.sh

  - mkdir -p /etc/containers && touch /etc/containers/nodocker
  - systemctl enable podman.socket

  # --- aidev: agentic CLIs + Node-based LSPs (npm-globally installed) ---
  # System-wide install under /usr/lib/node_modules with shims in
  # /usr/local/bin. npm's global prefix on Ubuntu is /usr by default; we
  # repoint to /usr/local so apt-managed /usr files stay untouched and the
  # CLIs survive an Ubuntu npm purge. The bash + yaml LSPs ship here
  # (not on sysdev) because they require Node, which sysdev intentionally
  # doesn't carry.
  - |
    set -eu
    mkdir -p /usr/local/lib/node_modules
    npm config set prefix /usr/local --global
    npm install -g --omit=dev \
        @anthropic-ai/claude-code \
        @openai/codex \
        @google/gemini-cli \
        opencode-ai \
        bash-language-server \
        yaml-language-server
    # Sanity: each CLI should print its version.
    claude --version 2>/dev/null || claude-code --version 2>/dev/null || true
    codex --version 2>/dev/null || true
    gemini --version 2>/dev/null || true
    opencode --version 2>/dev/null || true
    bash-language-server --version 2>/dev/null || true
    yaml-language-server --version 2>/dev/null || true

  # pi (https://pi.dev). Curl-piped installer, run as root so the binary
  # lands in a system path. The installer is opaque w.r.t. version
  # pinning -- if reproducibility bites we'll switch to a pinned URL.
  - |
    set -eu
    curl -fsSL https://pi.dev/install.sh | sh
    command -v pi >/dev/null 2>&1 && pi --version || true

  # --- WSL config (inert on flashable, used by wsl --import on the WSL
  # rootfs derived from the same bake). systemd=true so podman, the agentic
  # CLIs, and the NVIDIA stack work the same as bare metal; default user
  # odus (UID 1000, matches useradd below). generateResolvConf=true lets
  # the Windows host hand us DNS.
  - |
    cat > /etc/wsl.conf <<'WSLCONF'
    [boot]
    systemd=true

    [user]
    default=odus

    [network]
    generateHosts=true
    generateResolvConf=true
    hostname=nosi-aidev

    [interop]
    enabled=true
    appendWindowsPath=true
    WSLCONF
    chmod 0644 /etc/wsl.conf

  - |
    cat > /etc/wsl-distribution.conf <<'WSLDIST'
    [oobe]
    defaultUid=1000
    defaultName=odus
    defaultGroups=sudo,kvm,render,video
    WSLDIST
    chmod 0644 /etc/wsl-distribution.conf

  # --- IOMMU / VFIO plumbing : copied from sysdev (flashable target) -----
  - |
    cat > /etc/modules-load.d/nosi-userspace-pci.conf <<'MODS'
    vfio-pci
    uio_pci_generic
    MODS
    cat > /etc/udev/rules.d/99-nosi-vfio.rules <<'RULES'
    SUBSYSTEM=="vfio", OWNER="root", GROUP="kvm", MODE="0660"
    RULES
  - |
    set -eu
    EXTRA="intel_iommu=on amd_iommu=on iommu=pt"
    if grep -q '^GRUB_CMDLINE_LINUX=' /etc/default/grub; then
        for arg in $EXTRA; do
            if ! grep -q "GRUB_CMDLINE_LINUX=.*\\b${arg}\\b" /etc/default/grub; then
                sed -i "s/^GRUB_CMDLINE_LINUX=\"\(.*\)\"$/GRUB_CMDLINE_LINUX=\"\1 ${arg}\"/" /etc/default/grub
            fi
        done
    else
        printf '\nGRUB_CMDLINE_LINUX="%s"\n' "$EXTRA" >> /etc/default/grub
    fi
    update-grub

  - |
    cat > /usr/local/bin/nosi-pci-mode <<'SCRIPT'
    #!/bin/sh
    set -eu

    case "${1:-status}" in
        status)
            echo "cmdline: $(cat /proc/cmdline)"
            case " $(cat /proc/cmdline) " in
                *' intel_iommu=on '*|*' amd_iommu=on '*) echo "mode: vfio (IOMMU on)" ;;
                *' intel_iommu=off '*|*' amd_iommu=off '*) echo "mode: uio (IOMMU off)" ;;
                *) echo "mode: unset" ;;
            esac
            exit 0
            ;;
        vfio)
            add="intel_iommu=on amd_iommu=on iommu=pt"
            del="intel_iommu=off amd_iommu=off"
            ;;
        uio)
            add="intel_iommu=off amd_iommu=off"
            del="intel_iommu=on amd_iommu=on iommu=pt"
            ;;
        *)
            echo "usage: $0 {vfio|uio|status}" >&2
            exit 2
            ;;
    esac

    if command -v grubby >/dev/null 2>&1; then
        sudo grubby --update-kernel=ALL --remove-args="$del" >/dev/null || true
        sudo grubby --update-kernel=ALL --args="$add"
    else
        cfg=/etc/default/grub
        for a in $del; do
            sudo sed -i "s/\b${a}\b//g; s/  */ /g; s/ \"/\"/g" "$cfg"
        done
        for a in $add; do
            grep -q "$a" "$cfg" || \
                sudo sed -i "s/^GRUB_CMDLINE_LINUX=\"\(.*\)\"$/GRUB_CMDLINE_LINUX=\"\1 ${a}\"/" "$cfg"
        done
        sudo update-grub
    fi
    echo "Kernel cmdline updated to '$1' mode. Reboot for changes to take effect."
    SCRIPT
    chmod 0755 /usr/local/bin/nosi-pci-mode

  # /etc/motd banner regenerated each boot by nosi-motd.service.
  - |
    cat > /usr/local/bin/nosi-motd <<'SCRIPT'
    #!/bin/sh
    set -eu

    . /etc/os-release 2>/dev/null || true
    distro="${PRETTY_NAME:-Linux}"
    kernel="$(uname -r)"
    arch="$(uname -m)"
    host="$(hostnamectl --static 2>/dev/null || hostname)"

    ips=""
    while IFS= read -r line; do
        iface="$(echo "$line" | awk '{print $2}')"
        addr="$(echo "$line" | awk '{print $4}' | cut -d/ -f1)"
        [ -z "$addr" ] && continue
        ips="${ips}${ips:+, }${addr} (${iface})"
    done <<EOF
    $(ip -4 -o addr show scope global 2>/dev/null)
    EOF
    [ -z "$ips" ] && ips="(none)"

    case " $(cat /proc/cmdline) " in
        *' intel_iommu=on '*|*' amd_iommu=on '*) iommu="vfio (IOMMU on)" ;;
        *' intel_iommu=off '*|*' amd_iommu=off '*) iommu="uio  (IOMMU off)" ;;
        *) iommu="unset" ;;
    esac

    hp_count="$(awk '/HugePages_Total:/ {print $2}' /proc/meminfo)"
    hp_size_kb="$(awk '/Hugepagesize:/ {print $2}' /proc/meminfo)"
    if [ "${hp_count:-0}" -gt 0 ]; then
        hp_mib=$(( hp_count * hp_size_kb / 1024 ))
        hugepgs="${hp_count} x ${hp_size_kb} kB = ${hp_mib} MiB"
    else
        hugepgs="0 (use 'hugepages' to allocate)"
    fi

    cpu_model="$(awk -F': ' '/^model name/ {print $2; exit}' /proc/cpuinfo)"
    cpu_count="$(nproc)"
    ram_kib="$(awk '/MemTotal:/ {print $2}' /proc/meminfo)"
    ram_gib=$(( ram_kib / 1024 / 1024 ))
    nvme_count="$(find /dev -maxdepth 1 -name 'nvme*n*' 2>/dev/null | wc -l)"

    cat <<EOM

      nosi aidev   ${distro}   Linux ${kernel}   ${arch}

      hostname:  ${host}
      ip:        ${ips}
      iommu:     ${iommu}
      hugepgs:   ${hugepgs}
      cpu:       ${cpu_model} x ${cpu_count}
      ram:       ${ram_gib} GiB
      nvme:      ${nvme_count}

      Tools:         rg fd fzf lazygit delta yazi oras gh just direnv
      Agentic CLIs:  claude  codex  gemini  opencode  pi
      Helpers:
        nosi-pci-mode {vfio|uio|status}   flip IOMMU on/off (reboot to apply)
        devbind                           bind/unbind PCI device to a driver
        hugepages                         inspect / reserve hugepages

    EOM
    SCRIPT
    chmod 0755 /usr/local/bin/nosi-motd

    cat > /etc/systemd/system/nosi-motd.service <<'UNIT'
    [Unit]
    Description=Generate nosi banner for /etc/motd
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=oneshot
    ExecStart=/bin/sh -c '/usr/local/bin/nosi-motd > /etc/motd'
    RemainAfterExit=yes

    [Install]
    WantedBy=multi-user.target
    UNIT
  - systemctl enable nosi-motd.service

  - passwd -l root
  # odus gets render+video on top of the sysdev sudo+kvm so it can drive
  # the NVIDIA userspace stack without sudo.
  - useradd --create-home --shell /bin/bash --groups sudo,kvm,render,video odus
  - |
    set -eu
    hash=$(openssl passwd -6 'odus.321')
    printf 'odus:%s\n' "$hash" | chpasswd -e
  - |
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  # --- snapd removal : same logic as sysdev-ubuntu -----------------------
  - |
    set -eu
    if command -v snap >/dev/null 2>&1; then
        for _ in 1 2 3; do
            snaps=$(snap list 2>/dev/null | awk 'NR>1 {print $1}') || true
            [ -z "$snaps" ] && break
            for s in $snaps; do
                snap remove --purge "$s" 2>/dev/null || true
            done
        done
    fi
    if dpkg-query -W -f='${Status}' snapd 2>/dev/null \
            | grep -q "install ok installed"; then
        DEBIAN_FRONTEND=noninteractive apt-get -y purge snapd
    fi
    apt-mark hold snapd 2>/dev/null || true
    rm -rf /root/snap /home/*/snap /snap /var/snap /var/lib/snapd /var/cache/snapd

  # --- headless-noise daemon prune : same logic as sysdev-ubuntu ---------
  - |
    set -eu
    to_purge=""
    for pkg in unattended-upgrades modemmanager packagekit packagekit-tools \
               udisks2 accountsservice \
               apport whoopsie pollinate needrestart \
               update-notifier-common \
               ubuntu-pro-client ubuntu-advantage-tools; do
        if dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null \
                | grep -q "install ok installed"; then
            to_purge="$to_purge $pkg"
        fi
    done
    if [ -n "$to_purge" ]; then
        DEBIAN_FRONTEND=noninteractive apt-get -y purge $to_purge
    fi
    apt-get -y autoremove --purge || true
    systemctl mask \
        apt-daily.service apt-daily.timer \
        apt-daily-upgrade.service apt-daily-upgrade.timer \
        fwupd.service fwupd-refresh.service fwupd-refresh.timer \
        motd-news.service motd-news.timer \
        man-db.service man-db.timer \
        e2scrub_all.service e2scrub_all.timer e2scrub_reap.service \
        polkit.service \
        smartd.service \
        multipathd.service multipathd.socket \
        networkd-dispatcher.service \
        2>/dev/null || true

  - rm -f /etc/ssh/ssh_host_*
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - cloud-init clean --logs --seed || true

  - |
    set -eu
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi ubuntu-aidev baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
