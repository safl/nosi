#cloud-config
# nosi base : FreeBSD 14.4-RELEASE. Default credentials: operator account
# `odus` with password `odus.321`, root locked, SSH password auth on.
# Per-instance SSH identity: host keys stripped at end of init,
# regenerated on first boot.
#
# Phase 2a: runs the shared provision/apply.sh chain (delivered as a
# base64 tarball in runcmd, see below) with the FreeBSD critical-path
# steps -- identity stamp, NIC-agnostic DHCP via rc.conf, rootfs grow via
# growfs, sshd, metadata + motd. The remaining Linux steps (DKMS, grub
# IOMMU, podman, snapd, upstream-release tools, pipx CLIs, ...) are not
# yet ported and stay Linux-only.
#
# Important: FreeBSD's BASIC-CLOUDINIT image runs *nuageinit*, the
# FreeBSD-native cloud-init-compatible re-implementation, not the
# Python cloud-init. nuageinit speaks a SUBSET of the user-data
# spec: users, ssh_authorized_keys, hashed_passwd, packages, runcmd,
# hostname all work; `power_state:`, `final_message:`, `growpart:`,
# `manage_etc_hosts:` do NOT. Hence the explicit `poweroff` at the end
# of runcmd (no power_state module) and the absence of those keys.

hostname: nosi-freebsd

ssh_pwauth: true

# Operator account: `odus` with password `odus.321`, passwordless sudo,
# pinned to UID 1000. `wheel` is FreeBSD's sudo group. The `freebsd`
# user from the base cloud image is left in place for now (Phase 2 may
# `pw userdel freebsd` once nuageinit's coverage is mapped out;
# nuageinit may not run a bootcmd that does that cleanly).
users:
  - name: odus
    uid: 1000
    gecos: nosi operator
    shell: /bin/sh
    groups: [wheel, operator]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: "$6$nosiOpRator$MNNihj4cU2CANkmlcYthq7Fa.U2r5VwwJxtm1TlqmznXizzkddi0sxKc3YnkgRpcvOLc2V7nOGpbp/tOyD5M81"

# Phase 1 package set: the "easy" ones that map cleanly to FreeBSD pkg
# names without per-distro thrash. Mirrors the Linux baseline minus
# anything Linux-specific (systemd-*, network-manager, *-microcode,
# linux-firmware). The deeper layers (upstream-release tools via
# step 20, pipx CLIs via step 22, ports-only specialties) wait for
# Phase 2 when the provision/steps/*.sh chain is audited for FreeBSD.
packages:
  # system basics
  - bash
  - bash-completion
  - ca_root_nss
  - curl
  - git
  - sudo
  - wget
  - unzip
  # build / dev
  - ccache               # transparent compiler cache; wraps gcc/clang
  - cmake                # ubiquitous C/C++ build orchestrator
  - cppcheck             # standalone C/C++ static analyzer
  - dwarves              # pahole: struct layout / padding from DWARF (kernel/BPF)
  - gmake                # gnu make; FreeBSD's `make` is bsdmake
  - meson
  - ninja
  - pkgconf
  - python3
  # Compilers + lldb are in the FreeBSD base system, not a pkg (clang
  # has been the system C/C++ compiler since FreeBSD 10). The helix
  # `lldb-dap` binary used for DAP debugging ships with base lldb.
  # baseline tools (per user-memory: must be pre-installed)
  - btop
  - fastfetch            # system info summary (maintained C successor to neofetch)
  - helix                # binary is /usr/local/bin/hx
  - zellij
  # productivity / shell quality of life
  - direnv
  - fd-find
  - fzf
  - gh                   # github CLI
  - git-delta
  - git-lfs
  - htop
  - ipmitool             # IPMI / BMC: lights-out mgmt, sensors, SEL on servers
  - jq
  - ripgrep
  # vpn: if_wg (WireGuard) is in the base kernel; tailscaled installs
  # dormant (pkg never enables rc services). Activate with
  # `service tailscaled enable && service tailscaled start && tailscale up`.
  - tailscale
  - wireguard-tools

# nuageinit doesn't honour cloud-init's write_files: directive (which the
# Linux variants use to drop the provision tree), so the provision/ tree
# is delivered instead as a base64 gzip tarball spliced in at the
# __NOSI_PROVISION_TARBALL__ marker in runcmd below and extracted to
# /opt/nosi at first boot. The tarball carries /opt/nosi/.nosi-version, so
# the build identity travels with it (no separate __NOSI_VERSION__ needed).

runcmd:
  # Reclaim uid 1000 for odus. nuageinit's users module runs before
  # runcmd and silently ignored our `uid: 1000` because the BASIC-
  # CLOUDINIT image's `freebsd` user already owned 1000 -- odus came
  # out at uid 1001. Delete the freebsd user, then `pw usermod -u 1000`
  # to align with the Linux variants' UID convention (and the
  # WSL/Linux-standard "first interactive user owns 1000" assumption
  # baked into wsl-distribution.conf etc.).
  - pw userdel -r freebsd 2>/dev/null || true
  - pw usermod odus -u 1000
  - chown -R 1000:1000 /home/odus

  # Lock root so the only login channel is odus (matches Linux variants).
  - pw lock root

  # Strip per-instance identity so first boot of the flashed image
  # regenerates it (host keys via sshd's first-boot keygen path,
  # hostid via /etc/rc.d/hostid).
  - rm -f /etc/ssh/ssh_host_*
  - rm -f /etc/hostid

  # Disable firstboot_freebsd_update. The BASIC-CLOUDINIT base image
  # ships with firstboot_freebsd_update_enable=YES, so the consumer's
  # first boot would pull the entire patch backlog
  # (14.4-RELEASE -> 14.4-RELEASE-pXX = thousands of binary patches)
  # from update.FreeBSD.org before LOGIN, gated by KEYWORD: firstboot
  # against the same /firstboot sentinel that runs nosi_clock_from_http
  # and nosi_firstboot_inventory. On a CI runner that easily exceeds
  # the qemu wrapper's 120s is_up() window. Operators who want patches
  # can run `freebsd-update fetch install` themselves.
  - sysrc firstboot_freebsd_update_enable=NO

  # Kernel + world source for headless work: buildkernel, out-of-tree
  # modules, sys/ headers. Pattern borrowed from xNVMe's FreeBSD bootimg
  # workflow (github.com/xnvme/xnvme/blob/main/cijoe/workflows/bootimg-
  # freebsd-14-amd64.yaml). src.txz is the canonical FreeBSD source
  # distribution for the running release (~250 MB compressed, extracts
  # to /usr/src at ~1.5 GB). nuageinit's runcmd PATH is sane enough
  # that `fetch` and `tar` resolve.
  - fetch -o /tmp/src.txz https://download.freebsd.org/releases/amd64/14.4-RELEASE/src.txz
  - tar -C / -xpf /tmp/src.txz
  - rm -f /tmp/src.txz

  # Strip /usr/lib/debug to recover ~200 MB. nosi headless operators
  # build their own kernels and don't generally need the prebuilt
  # debug symbols for the cloud image's kernel.
  - rm -rf /usr/lib/debug

  # Light cleanup; pkg cache is the main thing worth dropping.
  - pkg clean -aqy

  # Deliver + run the shared provision chain. nuageinit does not honour
  # cloud-init's write_files:, so the cijoe renderer inlines the whole
  # provision/ tree (+ /opt/nosi/.nosi-version) as a one-line base64 gzip
  # tarball at the '__NOSI_PROVISION_TARBALL__' token below. Decode with
  # base-system openssl + tar (nuageinit's runcmd PATH has no
  # /usr/local/bin), extract into /opt/nosi, then run apply.sh. We must
  # set a full PATH (nuageinit's runcmd PATH omits /usr/local/{s}bin):
  # apply.sh invokes each step via its `#!/usr/bin/env bash` shebang, and
  # the steps reach pkg tools (jq, hx, sysrc, ...) by name, so both bash
  # and those tools must be resolvable for the inherited child PATH.
  # apply.sh owns networking (rc.conf DHCP), rootfs grow (growfs), sshd
  # config, /etc/nosi-metadata.json (step 98) and /etc/motd (step 99), and
  # writes /etc/nosi/apply-ok -- the sentinel the smoketest gates publish
  # on. Separate single-line runcmd items (no heredoc / block scalar)
  # because nuageinit does not reliably deliver multi-line runcmd content.
  - mkdir -p /opt/nosi
  - echo '__NOSI_PROVISION_TARBALL__' | openssl base64 -d -A | tar -C /opt/nosi -xpf -
  - PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin /usr/local/bin/bash /opt/nosi/provision/apply.sh freebsd-14-headless

  # Trim apply.sh's pkg downloads (gdb + deps, uv, lazygit, ruff) from
  # /var/cache/pkg: the earlier `pkg clean` ran before apply.sh, so without
  # this they would ride along in the published image.
  - pkg clean -aqy

  # Wipe nuageinit's state cache before we power off. nuageinit caches
  # the compiled runcmd script at /var/cache/nuageinit/runcmds and will
  # replay it on EVERY subsequent boot if left in place -- the first
  # bake attempt's smoketest VM caught that the hard way (poweroff
  # re-ran during smoketest boot, sshd never came up, timeout). Clearing
  # the cache means a fresh boot picks up whatever new seed it finds
  # (smoketest VM gets its own SSH key seed; operator-flashed first boot
  # gets no seed and nuageinit exits cleanly).
  - rm -rf /var/cache/nuageinit

  # nuageinit doesn't implement cloud-init's power_state module; an
  # explicit poweroff is how we hand control back to cijoe so the bake
  # completes. Must be the last entry: nuageinit runs runcmds serially
  # and anything after this won't execute.
  - poweroff
