#cloud-config
# nosi base : Debian 13 (trixie). Default credentials: operator account
# `odus` with password `odus.321`, root locked, SSH password auth on (operators
# rotate the password before exposing the appliance). Per-instance SSH
# identity: host keys are stripped at the end of cloud-init; sshd's stock
# preset regenerates them on first boot of the flashed instance.
#
# bty can still override identity at flash time by writing a fresh seed to
# /var/lib/cloud/seed/nocloud/; cloud-init runs again on first boot because
# we wipe its instance state below.

hostname: nosi-debian
fqdn: nosi-debian.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

# Strip the base cloud image's default user (`debian`) before cloud-init's
# users module runs. Two reasons: avoid an unused account in /etc/passwd,
# and free UID 1000 so odus can claim it (the WSL/Linux convention for
# the first interactive user; lots of tooling assumes UID 1000 = primary
# operator).
bootcmd:
  - userdel -r debian 2>/dev/null || true
  # The Debian cloud image ships APT sources with `Components: main` only,
  # so the microcode + firmware packages in the packages: list below
  # (non-free-firmware section) were silently unavailable -- cloud-init
  # filters unavailable names out of the apt install and only WARNS, so
  # the bake stayed green while every flashed box ran without CPU
  # microcode mitigations. Enable the full component set before the
  # package module runs; the flashed image keeps it, so operators can
  # apt install firmware later too.
  - "sed -i 's/^Components: main$/Components: main contrib non-free non-free-firmware/' /etc/apt/sources.list.d/debian.sources"

# Operator account: `odus` with password `odus.321`, passwordless sudo,
# pinned to UID 1000. Created here (cloud-init users-module) rather than
# in runcmd because users-module calls `useradd -p HASH`, which writes
# the hash straight to /etc/shadow without going through PAM (so
# pam_pwquality cannot reject `odus.321` for containing the username),
# without depending on `openssl` being installed at runcmd time, and
# without the runcmd hazard that a single non-zero exit silently skips
# later items. Hash is `openssl passwd -6 -salt nosiOpRator odus.321`;
# salt is fixed so identical bakes produce identical /etc/shadow.
# `- default` is intentionally absent; the base image's default user is
# gone (bootcmd). Root is locked in runcmd below. The default password
# stays active out of the box so CI jobs can flash and ssh straight in;
# step 29 just marks the system as on the default and the motd warns at
# every interactive login until the operator rotates with `passwd odus`.
# Operators who want a personal identity rename odus rather than create
# a second account (see provision/README.md).
users:
  - name: odus
    uid: 1000
    gecos: nosi operator
    shell: /bin/bash
    groups: [sudo, kvm]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: "$6$nosiOpRator$MNNihj4cU2CANkmlcYthq7Fa.U2r5VwwJxtm1TlqmznXizzkddi0sxKc3YnkgRpcvOLc2V7nOGpbp/tOyD5M81"

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# cloud-init's apt module pulls Install-Recommends by default, which
# inflates the image by GBs on a dev-shape package list this size.
# Drop Recommends + Suggests; the explicit packages: list already names
# everything we want.
apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

# Refresh and upgrade the base image's packages before installing the
# `packages:` list below: a cloud base is a point-in-time snapshot, and
# without an upgrade the baked nosi image inherits whatever CVEs the
# upstream snapshot was carrying. Adds a couple of minutes to bake time.
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  # NTP via systemd's own daemon. Cloud-image baseline pulls it via
  # systemd Recommends today; name it explicitly so we survive any
  # future upstream dependency tweak. Clock-correctness is silently
  # load-bearing -- without it, apt-get update rejects InRelease
  # signatures ("Not live until <future ts>"), oras pull rejects TLS
  # NotBefore on rotated certs, etc.
  - systemd-timesyncd
  # user daily-driver baseline (helix + zellij + lazygit + yazi installed
  # from upstream tarballs in runcmd; distro packages skew old and Ubuntu
  # 26.04 dropped helix from universe at one point). taplo + marksman
  # LSPs are installed from upstream in runcmd (single native binaries).
  - bash-completion      # autoloads /etc/bash_completion.d/* on interactive bash
  - btop
  - fastfetch            # system info summary (maintained C successor to neofetch)
  - direnv               # per-directory env vars; bash hook in /etc/profile.d
  - fd-find              # /usr/bin/fdfind; symlinked to fd in runcmd
  - fzf
  - gh                   # GitHub CLI
  - git
  - git-delta            # `delta` pager, wired into /etc/gitconfig
  - git-lfs
  - htop
  - just                 # task runner (sister to make-as-task-runner)
  - meson
  - ninja-build
  - parallel             # GNU parallel
  - ripgrep
  - shellcheck           # bash linter; headless's substitute for the
                         # Node-based bash-language-server (agentic-cli addon)
  - stress-ng            # CPU / memory stress for thermals + bench
  - sysstat              # iostat / sar / mpstat
  - time                 # GNU time (verbose vs the bash builtin)
  - unzip                # yazi ships as a zip in its releases
  - libicu-dev           # ICU runtime for marksman (.NET-based markdown LSP);
                         # without it dotnet aborts with "Couldn't find a valid
                         # ICU package" and step 20 fails fast on marksman
  - linux-headers-amd64   # DKMS / out-of-tree modules; Debian's meta
                          # (Ubuntu's analog is linux-headers-generic)
  - linux-perf            # Debian splits perf out of linux-tools-*; this
                          # is the equivalent metapackage
  # network & debug
  - curl
  - bind9-dnsutils        # dig/nslookup; the dnsutils transitional name is gone in trixie/resolute
  - jq
  - lsof
  - mtr-tiny
  - network-manager       # provides nmtui for interactive interface config
  - nmap
  - strace
  - tcpdump
  - wget
  - wireguard-tools      # wg / wg-quick for the in-kernel module; dormant until configured
  # build & dev (compilers, LSPs, linters, debugger / memory tools)
  - build-essential
  - ccache              # transparent compiler cache; wraps gcc/clang
  - clang
  - clang-tools         # clang-format, clang-tidy
  - clangd              # C/C++ LSP
  - cmake               # ubiquitous C/C++ build orchestrator
  - cppcheck            # standalone C/C++ static analyzer
  - dwarves             # pahole: struct layout / padding from DWARF (kernel/BPF)
  - gdb
  - lldb                # helix DAP debugger backend (lldb-dap binary)
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  # containers. crun + fuse-overlayfs + dbus-user-session are podman's
  # Recommends on Debian/Ubuntu (Fedora has them as hard deps); we drop
  # Recommends globally for image size, so name them explicitly here.
  # Without crun, podman falls back to runc which mismanages cgroup v2;
  # without dbus-user-session, rootless cgroup delegation fails.
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt                # /usr/bin/pasta for podman rootless networking
  - podman
  - podman-docker
  - podman-compose       # `podman compose` provider; without it the wrapper
                         # dies with "looking up compose provider failed"
  - skopeo
  # hardware & storage
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  # firmware for bare-metal targets flashed via bty: i915 GuC/HuC (Alder
  # Lake-P et al.), iwlwifi, regulatory.db, etc. Debian 13 cloud images
  # already enable the non-free-firmware component by default.
  - firmware-misc-nonfree
  # CPU microcode (early-load via initramfs). intel-microcode and
  # amd64-microcode both live in non-free-firmware in Debian 13;
  # post-install hooks regenerate initramfs so the microcode prepend
  # cpio is in place for the next boot. Errata fixes here are silently
  # load-bearing for stability on consumer Intel SKUs (e.g. Alder Lake-N
  # in the GMKtec NucBox G5) and recent AMD parts (Zen3+ in the G10).
  - intel-microcode
  - amd64-microcode
  # local virtualisation
  - ovmf
  - qemu-system-x86
  # full-system arm/arm64 too, so an x86 box can boot a Pi / arm64 guest
  # under cijoe (the qemu-system-arm package ships both qemu-system-arm and
  # qemu-system-aarch64). User-mode cross-arch (binaries, chroots) is below.
  - qemu-system-arm
  - qemu-utils
  # Cross-arch user-mode emulation: the static qemu-<arch> interpreters +
  # binfmt registrations so the kernel transparently runs foreign-arch
  # binaries (arm64 in an x86 chroot, `podman --platform`, etc.).
  # binfmt-support owns the boot-time registration. Complements qemu-system-x86
  # (system emulation for cijoe guests) and makes `make build-rpi` work from an
  # x86 host / the ubuntu-2604-wsl shape with no extra setup.
  - qemu-user-static
  - binfmt-support
  # cloud-init seed tooling: cloud-localds (cloud-image-utils) + mkisofs
  # (genisoimage) let an on-target cijoe build a NoCloud seed.iso to boot
  # cloud-init guests -- the docker bootstrap shape's job, and any guest
  # workflow cijoe drives.
  - genisoimage
  - cloud-image-utils

# Drop the nosi provision/ tree into /opt/nosi/provision/. The
# __NOSI_PROVISION_FILES__ marker is expanded at bake time by
# cijoe/scripts/userdata_render.py: it replaces this comment with one
# write_files: entry per file under provision/ (apply.sh, lib/*,
# steps/*), chmod 0755. The runcmd: section below then invokes
# /opt/nosi/provision/apply.sh, which is also the same script
# operators run on a vanilla Hetzner VM to reach image parity.
write_files:
  # __NOSI_PROVISION_FILES__

runcmd:

  # nosi provision: r8125 DKMS + softdep, clock-from-http + NTP enable,
  # nosi-motd renderer + service, nosi-firstboot-inventory + service.
  # Each step under provision/steps/ is independently idempotent and
  # cross-distro where it makes sense. Same apply.sh runs on a vanilla
  # Hetzner VM (`sudo /opt/nosi/provision/apply.sh debian-13-headless`) to
  # reach this image's parity.
  - /opt/nosi/provision/apply.sh debian-13-headless

  # odus itself is created by the top-level `users:` block (hashed_passwd
  # written straight to /etc/shadow). All that's left here is locking root
  # so the only login channel is odus.
  - passwd -l root

  # SSH host-key hygiene: openssh-server's postinst generated host keys
  # during apt install; remove them now so every flashed instance gets
  # unique keys via the stock systemd preset on first boot.
  - rm -f /etc/ssh/ssh_host_*

  # machine-id: regenerated by systemd-machine-id-setup on first boot when empty.
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id

  # cloud-init state cache: clear it so cloud-init runs fresh on first boot
  # of the flashed instance (against whatever seed bty injects, or the
  # built-in NoCloud absence which is fine; defaults from this run stay).
  - cloud-init clean --logs --seed || true

  # Deep cleanup: trim non-English locales, systemd journal, build logs,
  # stray Python bytecode, and drop apt orphans + uninstallable archives
  # before the final cache wipe below.
  - |
    set -eu
    # Drop translations for everything except the English / C locales.
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  # Clock floor: systemd (PID 1) reads /usr/lib/clock-epoch's mtime at boot
  # and uses it as the minimum acceptable system time. A flashed box with a
  # dead CMOS battery (or RTC freshly reset to ~1970) would otherwise come
  # up at the epoch and reject every TLS handshake ("certificate not yet
  # valid"), breaking apt-get update / curl / cloud-init's own seed fetch.
  # Touch it last so the mtime is as close to bake time as possible;
  # systemd-timesyncd (already running from the cloud base) refines the
  # clock against NTP once the network is up.
  - touch /usr/lib/clock-epoch

  # Trim caches for a smaller image.
  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi debian-13-headless baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
