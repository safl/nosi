#cloud-config
# nosi base : Debian 13 (trixie). Default credentials: operator account
# `odus` with password `odus`, root locked, SSH password auth on (operators
# rotate the password before exposing the appliance). Per-instance SSH
# identity: host keys are stripped at the end of cloud-init; sshd's stock
# preset regenerates them on first boot of the flashed instance.
#
# bty can still override identity at flash time by writing a fresh seed to
# /var/lib/cloud/seed/nocloud/; cloud-init runs again on first boot because
# we wipe its instance state below.

hostname: nosi-debian
fqdn: nosi-debian.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  # user daily-driver baseline
  - btop
  - git
  - helix
  - htop
  - meson
  - ninja-build
  - zellij
  # network & debug
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - nmap
  - strace
  - tcpdump
  - wget
  # build & dev (compilers, LSPs, linters, debugger / memory tools)
  - build-essential
  - clang
  - clang-tools         # clang-format, clang-tidy
  - clangd              # C/C++ LSP
  - gdb
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  # containers
  - buildah
  - podman
  - podman-docker
  - skopeo
  # hardware & storage
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  # local virtualisation
  - ovmf
  - qemu-system-x86
  - qemu-utils

runcmd:
  # Install uv + uvx from Astral upstream (not in Debian repos).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "nosi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version

  # Install Rust via rustup (system-wide, default stable toolchain + the
  # rust-analyzer LSP component). Same philosophy as the uv install above:
  # pull a current upstream toolchain rather than a distro package.
  - |
    set -eu
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile default
    /usr/local/cargo/bin/rustup component add rust-analyzer
    cat > /etc/profile.d/nosi-rust.sh <<'PROF'
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    case ":$PATH:" in
        *":/usr/local/cargo/bin:"*) : ;;
        *) export PATH="/usr/local/cargo/bin:$PATH" ;;
    esac
    PROF
    chmod 0644 /etc/profile.d/nosi-rust.sh
    /usr/local/cargo/bin/rustc --version

  # Python LSP / linter / formatter stack for helix:
  #   - ruff (linter + formatter, includes built-in `ruff server` LSP)
  #   - pyright (type-checking LSP)
  # Installed into a shared venv at /opt/python-tools, exposed via symlinks
  # in /usr/local/bin so every user gets them on PATH without setup.
  - |
    set -eu
    python3 -m venv /opt/python-tools
    /opt/python-tools/bin/pip install --no-cache-dir --upgrade pip
    /opt/python-tools/bin/pip install --no-cache-dir ruff pyright
    for bin in ruff pyright pyright-langserver; do
        ln -sf /opt/python-tools/bin/$bin /usr/local/bin/$bin
    done
    ruff --version
    pyright --version

  # System-wide `pipx ensurepath` equivalent.
  - |
    cat > /etc/profile.d/nosi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-localbin.sh

  # Suppress podman-docker's "emulating docker" banner.
  - mkdir -p /etc/containers && touch /etc/containers/nodocker

  # Enable podman.socket so docker-compat clients work without setup.
  - systemctl enable podman.socket

  # Userspace PCI prerequisites for passing PCI devices through to qemu
  # guests or to podman containers (SPDK / DPDK / xNVMe / GPU-style work):
  #   - Preload vfio-pci and uio_pci_generic so devices can be bound to
  #     a userspace driver immediately.
  #   - udev rule hands /dev/vfio/* to the kvm group, which odus is in,
  #     so passthrough works without sudo.
  #   - GRUB cmdline gets intel_iommu / amd_iommu / iommu=pt so vfio
  #     actually has an IOMMU to talk to.
  # Hugepages are intentionally NOT reserved at build (the right count
  # depends on host RAM and workload); set at runtime with e.g.
  # `sudo sysctl -w vm.nr_hugepages=512` for 1 GiB of 2 MiB pages.
  - |
    cat > /etc/modules-load.d/nosi-userspace-pci.conf <<'MODS'
    vfio-pci
    uio_pci_generic
    MODS
    cat > /etc/udev/rules.d/99-nosi-vfio.rules <<'RULES'
    # /dev/vfio/* accessible to the kvm group so vfio passthrough works
    # for unprivileged users in that group (qemu -device vfio-pci=... ,
    # podman --device=/dev/vfio/N ...).
    SUBSYSTEM=="vfio", OWNER="root", GROUP="kvm", MODE="0660"
    RULES
  - |
    set -eu
    EXTRA="intel_iommu=on amd_iommu=on iommu=pt"
    if grep -q '^GRUB_CMDLINE_LINUX=' /etc/default/grub; then
        for arg in $EXTRA; do
            if ! grep -q "GRUB_CMDLINE_LINUX=.*\\b${arg}\\b" /etc/default/grub; then
                sed -i "s/^GRUB_CMDLINE_LINUX=\"\(.*\)\"$/GRUB_CMDLINE_LINUX=\"\1 ${arg}\"/" /etc/default/grub
            fi
        done
    else
        printf '\nGRUB_CMDLINE_LINUX="%s"\n' "$EXTRA" >> /etc/default/grub
    fi
    update-grub

  # Operator account: `odus` with password `odus`, passwordless sudo. Lock
  # root so the only login channel is `odus`. Rotate the password before
  # exposing to anything beyond a trusted network.
  - passwd -l root
  - useradd --create-home --shell /bin/bash --groups sudo,kvm odus
  - echo 'odus:odus' | chpasswd
  - |
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  # SSH host-key hygiene: openssh-server's postinst generated host keys
  # during apt install; remove them now so every flashed instance gets
  # unique keys via the stock systemd preset on first boot.
  - rm -f /etc/ssh/ssh_host_*

  # machine-id: regenerated by systemd-machine-id-setup on first boot when empty.
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id

  # cloud-init state cache: clear it so cloud-init runs fresh on first boot
  # of the flashed instance (against whatever seed bty injects, or the
  # built-in NoCloud absence which is fine; defaults from this run stay).
  - cloud-init clean --logs --seed || true

  # Trim caches for a smaller image.
  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi debian-sysdev baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
