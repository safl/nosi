#cloud-config
# nosi base : Debian 13 (trixie). Default credentials: operator account
# `odus` with password `odus.321`, root locked, SSH password auth on (operators
# rotate the password before exposing the appliance). Per-instance SSH
# identity: host keys are stripped at the end of cloud-init; sshd's stock
# preset regenerates them on first boot of the flashed instance.
#
# bty can still override identity at flash time by writing a fresh seed to
# /var/lib/cloud/seed/nocloud/; cloud-init runs again on first boot because
# we wipe its instance state below.

hostname: nosi-debian
fqdn: nosi-debian.local
manage_etc_hosts: true

timezone: UTC

ssh_pwauth: true

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# cloud-init's apt module pulls Install-Recommends by default, which
# inflates the image by GBs on a dev-flavor package list this size.
# Drop Recommends + Suggests; the explicit packages: list already names
# everything we want.
apt:
  conf: |
    APT::Install-Recommends "false";
    APT::Install-Suggests "false";

# Refresh and upgrade the base image's packages before installing the
# `packages:` list below: a cloud base is a point-in-time snapshot, and
# without an upgrade the baked nosi image inherits whatever CVEs the
# upstream snapshot was carrying. Adds a couple of minutes to bake time.
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  # user daily-driver baseline (helix + zellij + lazygit + yazi installed
  # from upstream tarballs in runcmd; distro packages skew old and Ubuntu
  # 26.04 dropped helix from universe at one point). taplo + marksman
  # LSPs are installed from upstream in runcmd (single native binaries).
  - bash-completion      # autoloads /etc/bash_completion.d/* on interactive bash
  - btop
  - direnv               # per-directory env vars; bash hook in /etc/profile.d
  - fd-find              # /usr/bin/fdfind; symlinked to fd in runcmd
  - fzf
  - gh                   # GitHub CLI
  - git
  - git-delta            # `delta` pager, wired into /etc/gitconfig
  - htop
  - just                 # task runner (sister to make-as-task-runner)
  - meson
  - ninja-build
  - ripgrep
  - shellcheck           # bash linter; sysdev's substitute for the
                         # Node-based bash-language-server (aidev only)
  - unzip                # yazi ships as a zip in its releases
  # network & debug
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - network-manager       # provides nmtui for interactive interface config
  - nmap
  - strace
  - tcpdump
  - wget
  # build & dev (compilers, LSPs, linters, debugger / memory tools)
  - build-essential
  - clang
  - clang-tools         # clang-format, clang-tidy
  - clangd              # C/C++ LSP
  - gdb
  - make
  - pipx
  - pkg-config
  - python3
  - valgrind
  # containers. crun + fuse-overlayfs + dbus-user-session are podman's
  # Recommends on Debian/Ubuntu (Fedora has them as hard deps); we drop
  # Recommends globally for image size, so name them explicitly here.
  # Without crun, podman falls back to runc which mismanages cgroup v2;
  # without dbus-user-session, rootless cgroup delegation fails.
  - buildah
  - crun
  - dbus-user-session
  - fuse-overlayfs
  - passt                # /usr/bin/pasta for podman rootless networking
  - podman
  - podman-docker
  - skopeo
  # hardware & storage
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  # firmware for bare-metal targets flashed via bty: i915 GuC/HuC (Alder
  # Lake-P et al.), iwlwifi, regulatory.db, etc. Debian 13 cloud images
  # already enable the non-free-firmware component by default.
  - firmware-misc-nonfree
  # local virtualisation
  - ovmf
  - qemu-system-x86
  - qemu-utils

runcmd:
  # Install uv + uvx from Astral upstream (not in Debian repos).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "nosi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version

  # Install Rust via rustup (system-wide, default stable toolchain + the
  # rust-analyzer LSP component). Same philosophy as the uv install above:
  # pull a current upstream toolchain rather than a distro package.
  - |
    set -eu
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile default
    /usr/local/cargo/bin/rustup component add rust-analyzer
    cat > /etc/profile.d/nosi-rust.sh <<'PROF'
    export RUSTUP_HOME=/usr/local/rustup
    export CARGO_HOME=/usr/local/cargo
    case ":$PATH:" in
        *":/usr/local/cargo/bin:"*) : ;;
        *) export PATH="/usr/local/cargo/bin:$PATH" ;;
    esac
    PROF
    chmod 0644 /etc/profile.d/nosi-rust.sh
    /usr/local/cargo/bin/rustc --version

  # Install Helix editor from upstream release. Distro packages lag
  # the upstream pace and Ubuntu 26.04 lost helix from universe at one
  # point; the upstream tarball is the only reliable channel across the
  # three variants. Runtime data lives at /usr/local/share/helix/runtime
  # and is found via $HELIX_RUNTIME (set in /etc/profile.d/nosi-helix.sh).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64-linux ;;
        aarch64) tarch=aarch64-linux ;;
        *) echo "nosi: unsupported arch $arch for helix" >&2; exit 1 ;;
    esac
    # Resolve latest tag via the releases/latest redirect (no jq dep).
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/helix-editor/helix/releases/latest \
        | sed 's#.*/tag/##')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/helix-editor/helix/releases/download/${ver}/helix-${ver}-${tarch}.tar.xz" \
        | tar -xJ -C "$tmp"
    src="$tmp/helix-${ver}-${tarch}"
    install -D -m 0755 "$src/hx" /usr/local/bin/hx
    mkdir -p /usr/local/share/helix
    rm -rf /usr/local/share/helix/runtime
    cp -a "$src/runtime" /usr/local/share/helix/runtime
    rm -rf "$tmp"
    cat > /etc/profile.d/nosi-helix.sh <<'PROF'
    export HELIX_RUNTIME=/usr/local/share/helix/runtime
    PROF
    chmod 0644 /etc/profile.d/nosi-helix.sh
    /usr/local/bin/hx --version

  # Install Zellij from upstream release (single static binary, musl).
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  ztarget=x86_64-unknown-linux-musl ;;
        aarch64) ztarget=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for zellij" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/zellij-org/zellij/releases/latest/download/zellij-${ztarget}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/zellij"
    rm -rf "$tmp"
    /usr/local/bin/zellij --version

  # Install lazygit from upstream release. Release filenames embed the
  # version, so resolve via the /releases/latest redirect first (mirrors
  # the helix block above). Single static Go binary.
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  larch=Linux_x86_64 ;;
        aarch64) larch=Linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for lazygit" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/jesseduffield/lazygit/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/jesseduffield/lazygit/releases/download/v${ver}/lazygit_${ver}_${larch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/lazygit"
    rm -rf "$tmp"
    /usr/local/bin/lazygit --version

  # Install yazi from upstream release (musl static binary). Yazi ships
  # the `yazi` UI binary plus a `ya` CLI helper; both go to /usr/local/bin.
  # Release artefact is a .zip; needs `unzip` from packages.
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  yarch=x86_64-unknown-linux-musl ;;
        aarch64) yarch=aarch64-unknown-linux-musl ;;
        *) echo "nosi: unsupported arch $arch for yazi" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL -o "$tmp/yazi.zip" \
        "https://github.com/sxyazi/yazi/releases/latest/download/yazi-${yarch}.zip"
    unzip -q -d "$tmp" "$tmp/yazi.zip"
    install -m 0755 -t /usr/local/bin \
        "$tmp/yazi-${yarch}/yazi" \
        "$tmp/yazi-${yarch}/ya"
    rm -rf "$tmp"
    /usr/local/bin/yazi --version

  # Install taplo (TOML LSP) from upstream release. Single static Rust
  # binary, ships gzip-compressed in the release; gunzip straight into
  # /usr/local/bin.
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  tarch=x86_64 ;;
        aarch64) tarch=aarch64 ;;
        *) echo "nosi: unsupported arch $arch for taplo" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/tamasfe/taplo/releases/latest/download/taplo-full-linux-${tarch}.gz" \
        | gunzip > /usr/local/bin/taplo
    chmod 0755 /usr/local/bin/taplo
    /usr/local/bin/taplo --version

  # Install marksman (Markdown LSP) from upstream release. AOT-compiled
  # native binary, no .NET runtime needed.
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  march=x64 ;;
        aarch64) march=arm64 ;;
        *) echo "nosi: unsupported arch $arch for marksman" >&2; exit 1 ;;
    esac
    curl -fsSL "https://github.com/artempyanykh/marksman/releases/latest/download/marksman-linux-${march}" \
        -o /usr/local/bin/marksman
    chmod 0755 /usr/local/bin/marksman
    /usr/local/bin/marksman --version 2>/dev/null \
        || /usr/local/bin/marksman --help >/dev/null

  # Install oras (OCI Registry as Storage) from upstream release.
  # Single static Go binary. Primary tool for pulling nosi's own
  # published images from GHCR (`oras pull` resolves :latest and
  # writes blobs with their canonical filenames via the OCI title
  # annotation we set at push time), and generally useful for any
  # OCI-registry workflow.
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  oarch=linux_amd64 ;;
        aarch64) oarch=linux_arm64 ;;
        *) echo "nosi: unsupported arch $arch for oras" >&2; exit 1 ;;
    esac
    ver=$(curl -fsSLI -o /dev/null -w '%{url_effective}' \
        https://github.com/oras-project/oras/releases/latest \
        | sed 's#.*/tag/##' | sed 's/^v//')
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/oras-project/oras/releases/download/v${ver}/oras_${ver}_${oarch}.tar.gz" \
        | tar -xz -C "$tmp"
    install -m 0755 -t /usr/local/bin "$tmp/oras"
    rm -rf "$tmp"
    /usr/local/bin/oras version

  # Wire up fd (Debian/Ubuntu ship the binary as /usr/bin/fdfind to avoid
  # colliding with an unrelated `fd` package; symlink it to the canonical
  # name) and the system-wide /etc/gitconfig that enables `delta` as the
  # git diff/log/show pager. Operators who prefer the stock pager can
  # override per-user in ~/.gitconfig.
  - |
    set -eu
    if [ -x /usr/bin/fdfind ] && [ ! -e /usr/local/bin/fd ]; then
        ln -s /usr/bin/fdfind /usr/local/bin/fd
    fi
    cat > /etc/gitconfig <<'GITCONF'
    # nosi: system-wide git defaults.
    [core]
        pager = delta
    [interactive]
        diffFilter = delta --color-only
    [delta]
        navigate = true
        line-numbers = true
    [merge]
        conflictstyle = zdiff3
    GITCONF
    chmod 0644 /etc/gitconfig

  # Shared /opt/python-tools venv with the opinionated helix LSP /
  # linter / formatter stack and the userspace-PCI helpers:
  #   - ruff (linter + formatter, includes built-in `ruff server` LSP)
  #   - pyright (type-checking LSP)
  #   - devbind (sysfs-based PCI driver-binding manager, github.com/xnvme/devbind)
  #   - hugepages (Linux hugepages inspection + reservation, github.com/xnvme/hugepages)
  #   - iommu (manage the Linux IOMMU substrate via the kernel cmdline, github.com/safl/iommu)
  # Each console script is symlinked into /usr/local/bin so every user
  # gets them on PATH without setup.
  - |
    set -eu
    python3 -m venv /opt/python-tools
    /opt/python-tools/bin/pip install --no-cache-dir --upgrade pip
    /opt/python-tools/bin/pip install --no-cache-dir ruff pyright devbind hugepages iommu
    for bin in ruff pyright pyright-langserver devbind hugepages iommu; do
        ln -sf /opt/python-tools/bin/$bin /usr/local/bin/$bin
    done
    ruff --version
    pyright --version
    devbind --help >/dev/null 2>&1 || true
    hugepages --help >/dev/null 2>&1 || true
    iommu --help >/dev/null 2>&1 || true

  # Bash completions for the userspace-PCI helpers. Each tool ships
  # `--print-completion bash`; the autoloader from the `bash-completion`
  # package sources /etc/bash_completion.d/* on interactive shells, so
  # tab-completion is live on first login with zero per-user setup.
  - |
    set -eu
    for t in iommu devbind hugepages; do
        $t --print-completion bash > /etc/bash_completion.d/$t 2>/dev/null || true
    done

  # System-wide `pipx ensurepath` equivalent.
  - |
    cat > /etc/profile.d/nosi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-localbin.sh

  # direnv bash hook. Sourced by every interactive bash shell; sets up
  # the trap that .envrc files rely on. Guarded on direnv being on PATH
  # so removing the package later doesn't break login.
  - |
    cat > /etc/profile.d/nosi-direnv.sh <<'PROF'
    if command -v direnv >/dev/null 2>&1; then
        eval "$(direnv hook bash)"
    fi
    PROF
    chmod 0644 /etc/profile.d/nosi-direnv.sh

  # Suppress podman-docker's "emulating docker" banner.
  - mkdir -p /etc/containers && touch /etc/containers/nodocker

  # Enable podman.socket so docker-compat clients work without setup.
  - systemctl enable podman.socket

  # Userspace PCI prerequisites for passing PCI devices through to qemu
  # guests or to podman containers (SPDK / DPDK / xNVMe / GPU-style work):
  #   - Preload vfio-pci and uio_pci_generic so devices can be bound to
  #     a userspace driver immediately.
  #   - udev rule hands /dev/vfio/* to the kvm group, which odus is in,
  #     so passthrough works without sudo.
  #   - GRUB cmdline gets intel_iommu / amd_iommu / iommu=pt so vfio
  #     actually has an IOMMU to talk to.
  # Hugepages are intentionally NOT reserved at build (the right count
  # depends on host RAM and workload); set at runtime with e.g.
  # `sudo sysctl -w vm.nr_hugepages=512` for 1 GiB of 2 MiB pages.
  - |
    cat > /etc/modules-load.d/nosi-userspace-pci.conf <<'MODS'
    vfio-pci
    uio_pci_generic
    MODS
    cat > /etc/udev/rules.d/99-nosi-vfio.rules <<'RULES'
    # /dev/vfio/* accessible to the kvm group so vfio passthrough works
    # for unprivileged users in that group (qemu -device vfio-pci=... ,
    # podman --device=/dev/vfio/N ...).
    SUBSYSTEM=="vfio", OWNER="root", GROUP="kvm", MODE="0660"
    RULES
  - |
    set -eu
    EXTRA="intel_iommu=on amd_iommu=on iommu=pt"
    if grep -q '^GRUB_CMDLINE_LINUX=' /etc/default/grub; then
        for arg in $EXTRA; do
            if ! grep -q "GRUB_CMDLINE_LINUX=.*\\b${arg}\\b" /etc/default/grub; then
                sed -i "s/^GRUB_CMDLINE_LINUX=\"\(.*\)\"$/GRUB_CMDLINE_LINUX=\"\1 ${arg}\"/" /etc/default/grub
            fi
        done
    else
        printf '\nGRUB_CMDLINE_LINUX="%s"\n' "$EXTRA" >> /etc/default/grub
    fi
    update-grub

  # memlock: VFIO_IOMMU_MAP_DMA pins userspace pages against RLIMIT_MEMLOCK.
  # Stock Debian sets the soft limit at 64 MiB which is the exact threshold
  # DPDK/SPDK warns at and below which `devbind --list` will fire its
  # memlock-too-low diagnostic. limits.conf drop-in raises both to unlimited
  # system-wide so vfio-pci consumers don't trip on first boot.
  - |
    cat > /etc/security/limits.d/nosi-memlock.conf <<'LIMITS'
    *  soft  memlock  unlimited
    *  hard  memlock  unlimited
    LIMITS
    chmod 0644 /etc/security/limits.d/nosi-memlock.conf

  # /etc/motd banner: per-boot snapshot of system state useful to a
  # sysdev operator -- distro / kernel / IPs / IOMMU mode / hugepages /
  # CPU / RAM / NVMe count / helper hints. Regenerated by a systemd
  # oneshot at boot so the IP and IOMMU columns are always current.
  - |
    cat > /usr/local/bin/nosi-motd <<'SCRIPT'
    #!/bin/sh
    # /usr/local/bin/nosi-motd: print the nosi login banner to stdout.
    # Wrapped by nosi-motd.service at boot into /etc/motd.
    set -eu

    . /etc/os-release 2>/dev/null || true
    distro="${PRETTY_NAME:-Linux}"
    kernel="$(uname -r)"
    arch="$(uname -m)"
    host="$(hostnamectl --static 2>/dev/null || hostname)"

    ips=""
    while IFS= read -r line; do
        iface="$(echo "$line" | awk '{print $2}')"
        addr="$(echo "$line" | awk '{print $4}' | cut -d/ -f1)"
        [ -z "$addr" ] && continue
        ips="${ips}${ips:+, }${addr} (${iface})"
    done <<EOF
    $(ip -4 -o addr show scope global 2>/dev/null)
    EOF
    [ -z "$ips" ] && ips="(none)"

    iommu="$(iommu show 2>/dev/null | awk '/^mode:/ {print $2}')"
    [ -z "$iommu" ] && iommu="unset"

    hp_count="$(awk '/HugePages_Total:/ {print $2}' /proc/meminfo)"
    hp_size_kb="$(awk '/Hugepagesize:/ {print $2}' /proc/meminfo)"
    if [ "${hp_count:-0}" -gt 0 ]; then
        hp_mib=$(( hp_count * hp_size_kb / 1024 ))
        hugepgs="${hp_count} x ${hp_size_kb} kB = ${hp_mib} MiB"
    else
        hugepgs="0 (use 'hugepages' to allocate)"
    fi

    cpu_model="$(awk -F': ' '/^model name/ {print $2; exit}' /proc/cpuinfo)"
    cpu_count="$(nproc)"
    ram_kib="$(awk '/MemTotal:/ {print $2}' /proc/meminfo)"
    ram_gib=$(( ram_kib / 1024 / 1024 ))
    nvme_count="$(find /dev -maxdepth 1 -name 'nvme*n*' 2>/dev/null | wc -l)"

    cat <<EOM

      nosi sysdev   ${distro}   Linux ${kernel}   ${arch}

      hostname:  ${host}
      ip:        ${ips}
      iommu:     ${iommu}
      hugepgs:   ${hugepgs}
      cpu:       ${cpu_model} x ${cpu_count}
      ram:       ${ram_gib} GiB
      nvme:      ${nvme_count}

      Tools:     rg fd fzf lazygit delta yazi oras gh just direnv
      Helpers:
        iommu {show|off-for-uio|off-for-vfio|strict|pt}   IOMMU substrate (reboot to apply)
        devbind                                           bind/unbind PCI device to a driver
        hugepages                                         inspect / reserve hugepages

    EOM
    SCRIPT
    chmod 0755 /usr/local/bin/nosi-motd

    cat > /etc/systemd/system/nosi-motd.service <<'UNIT'
    [Unit]
    Description=Generate nosi banner for /etc/motd
    After=network-online.target
    Wants=network-online.target

    [Service]
    Type=oneshot
    ExecStart=/bin/sh -c '/usr/local/bin/nosi-motd > /etc/motd'
    RemainAfterExit=yes

    [Install]
    WantedBy=multi-user.target
    UNIT
  - systemctl enable nosi-motd.service

  # nosi-firstboot-inventory: forensic snapshot to /var/log/nosi-firstboot.txt
  # on first boot only. lspci / lsblk / iommu / devbind / hugepages / ip /
  # cmdline / CPU / RAM. Useful to diff against later state when something
  # broke and you want to know what changed since flash. Runs exactly once:
  # ConditionPathExists=!/var/log/nosi-firstboot.txt short-circuits later
  # boots once the file is written.
  - |
    cat > /usr/local/bin/nosi-firstboot-inventory <<'SCRIPT'
    #!/bin/sh
    set -eu
    out=/var/log/nosi-firstboot.txt
    {
        echo "# nosi-firstboot-inventory $(date -Iseconds)"
        echo
        echo "## /etc/os-release"
        cat /etc/os-release 2>/dev/null || true
        echo
        echo "## uname -a"
        uname -a
        echo
        echo "## /proc/cmdline"
        cat /proc/cmdline
        echo
        echo "## ip -br a"
        ip -br a 2>/dev/null || true
        echo
        echo "## lsblk"
        lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT 2>/dev/null || true
        echo
        echo "## lspci -nn"
        lspci -nn 2>/dev/null || true
        echo
        echo "## nvme list"
        nvme list 2>/dev/null || true
        echo
        echo "## iommu show"
        iommu show 2>/dev/null || true
        echo
        echo "## devbind --list"
        devbind --list 2>/dev/null || true
        echo
        echo "## hugepages info"
        hugepages info 2>/dev/null || true
        echo
        echo "## free -h"
        free -h
        echo
        echo "## prlimit (memlock is the relevant one for vfio-pci / DPDK / SPDK)"
        prlimit 2>/dev/null || true
        echo
        echo "## CPU (first block of /proc/cpuinfo)"
        awk '/^$/ {exit} 1' /proc/cpuinfo
    } > "$out"
    SCRIPT
    chmod 0755 /usr/local/bin/nosi-firstboot-inventory

    cat > /etc/systemd/system/nosi-firstboot-inventory.service <<'UNIT'
    [Unit]
    Description=Capture first-boot inventory to /var/log/nosi-firstboot.txt
    After=network-online.target nosi-motd.service
    Wants=network-online.target
    ConditionPathExists=!/var/log/nosi-firstboot.txt

    [Service]
    Type=oneshot
    ExecStart=/usr/local/bin/nosi-firstboot-inventory
    RemainAfterExit=yes

    [Install]
    WantedBy=multi-user.target
    UNIT
  - systemctl enable nosi-firstboot-inventory.service

  # Operator account: `odus` with password `odus.321`, passwordless sudo. Lock
  # root so the only login channel is `odus`. Rotate the password before
  # exposing to anything beyond a trusted network.
  - passwd -l root
  - useradd --create-home --shell /bin/bash --groups sudo,kvm odus
  # See fedora variant: pre-hash and use chpasswd -e so PAM's
  # pam_pwquality cannot silently reject the password.
  - |
    set -eu
    hash=$(openssl passwd -6 'odus.321')
    printf 'odus:%s\n' "$hash" | chpasswd -e
  - |
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  # Minimize background daemons / timers. Stock cloud images carry a
  # collection of services that wake up to refresh apt / firmware /
  # man-db / motd; on a flashed dev box they cause unexpected IO + apt
  # locks at random times. Mask the noisy ones and purge
  # unattended-upgrades outright.
  - |
    set -eu
    # Purge headless-useless daemons that the base image may carry:
    #   unattended-upgrades  -- apt churn at random times
    #   modemmanager         -- probes /dev/ttyUSB* with AT commands
    #                           and breaks USB-serial dev work
    #   packagekit*          -- D-Bus desktop package shim that races
    #                           dpkg/apt for the rpm/dpkg lock
    #   udisks2              -- D-Bus storage automounter for desktops;
    #                           sysdev uses mount/lsblk directly
    # Iterate so a not-present package is a no-op rather than aborting
    # the whole apt-get call.
    to_purge=""
    for pkg in unattended-upgrades modemmanager packagekit packagekit-tools \
               udisks2 accountsservice; do
        if dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null \
                | grep -q "install ok installed"; then
            to_purge="$to_purge $pkg"
        fi
    done
    if [ -n "$to_purge" ]; then
        DEBIAN_FRONTEND=noninteractive apt-get -y purge $to_purge
    fi
    apt-get -y autoremove --purge || true
    # polkit stays installed (libs link against it and a --purge can
    # cascade into unrelated packages) but its daemon is masked.
    # multipathd: only meaningful with SAN multipath. networkd-dispatcher:
    # runs hooks from /etc/networkd-dispatcher/*.d which we ship empty.
    systemctl mask \
        apt-daily.service apt-daily.timer \
        apt-daily-upgrade.service apt-daily-upgrade.timer \
        fwupd.service fwupd-refresh.service fwupd-refresh.timer \
        motd-news.service motd-news.timer \
        man-db.service man-db.timer \
        e2scrub_all.service e2scrub_all.timer e2scrub_reap.service \
        polkit.service \
        smartd.service \
        multipathd.service multipathd.socket \
        networkd-dispatcher.service \
        2>/dev/null || true

  # SSH host-key hygiene: openssh-server's postinst generated host keys
  # during apt install; remove them now so every flashed instance gets
  # unique keys via the stock systemd preset on first boot.
  - rm -f /etc/ssh/ssh_host_*

  # machine-id: regenerated by systemd-machine-id-setup on first boot when empty.
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id

  # cloud-init state cache: clear it so cloud-init runs fresh on first boot
  # of the flashed instance (against whatever seed bty injects, or the
  # built-in NoCloud absence which is fine; defaults from this run stay).
  - cloud-init clean --logs --seed || true

  # Deep cleanup: trim non-English locales, systemd journal, build logs,
  # stray Python bytecode, and drop apt orphans + uninstallable archives
  # before the final cache wipe below.
  - |
    set -eu
    # Drop translations for everything except the English / C locales.
    if [ -d /usr/share/locale ]; then
        find /usr/share/locale -mindepth 1 -maxdepth 1 -type d \
            ! -name 'en' ! -name 'en_*' ! -name 'C' ! -name 'C.*' \
            -exec rm -rf {} + 2>/dev/null || true
    fi
    journalctl --vacuum-size=1M 2>/dev/null || true
    rm -rf /var/log/installer /var/log/journal/* /var/log/dpkg.log* /var/log/apt
    find /usr /opt /root /home -type d -name __pycache__ \
        -exec rm -rf {} + 2>/dev/null || true
    apt-get -y autoremove --purge
    apt-get -y autoclean

  # Trim caches for a smaller image.
  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /root/.cache /home/*/.cache /tmp/* /var/tmp/*

final_message: "nosi debian-sysdev baked in $UPTIME seconds; powering off"

power_state:
  mode: poweroff
  timeout: 60
  message: "nosi build complete"
