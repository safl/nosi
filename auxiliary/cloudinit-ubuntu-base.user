#cloud-config
# csi base — Ubuntu 24.04 LTS (noble). Anonymous: no users, no SSH keys,
# no hostname. bty injects per-target identity at flash time.

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# helix, zellij, btop, podman-docker live in universe.
apt:
  sources:
    universe:
      source: "deb http://archive.ubuntu.com/ubuntu noble universe"

package_update: true
package_upgrade: false

packages:
  - ca-certificates
  - openssh-server
  - sudo
  - systemd-resolved
  # user daily-driver baseline
  - btop
  - git
  - helix
  - htop
  - meson
  - ninja-build
  - zellij
  # network & debug
  - curl
  - dnsutils
  - jq
  - lsof
  - mtr-tiny
  - nmap
  - strace
  - tcpdump
  - wget
  # build & dev
  - build-essential
  - clang
  - gdb
  - make
  - pipx
  - pkg-config
  - python3
  # containers
  - buildah
  - podman
  - podman-docker
  - skopeo
  # hardware & storage
  - dmidecode
  - hdparm
  - lshw
  - nvme-cli
  - pciutils
  - smartmontools
  - usbutils
  # local virtualisation
  - ovmf
  - qemu-system-x86
  - qemu-utils

runcmd:
  - |
    set -eu
    arch=$(uname -m)
    case "$arch" in
        x86_64)  target=x86_64-unknown-linux-gnu ;;
        aarch64) target=aarch64-unknown-linux-gnu ;;
        *) echo "csi: unsupported arch $arch" >&2; exit 1 ;;
    esac
    tmp=$(mktemp -d)
    curl -fsSL "https://github.com/astral-sh/uv/releases/latest/download/uv-${target}.tar.gz" \
        | tar -xz -C "$tmp" "uv-${target}/uv" "uv-${target}/uvx"
    install -m 0755 -t /usr/local/bin "$tmp/uv-${target}/uv" "$tmp/uv-${target}/uvx"
    rm -rf "$tmp"
    uv --version
  - systemctl enable podman.socket
  - mkdir -p /etc/containers && touch /etc/containers/nodocker
  - |
    cat > /etc/profile.d/csi-localbin.sh <<'PROF'
    if [ -d "$HOME/.local/bin" ]; then
        case ":$PATH:" in
            *":$HOME/.local/bin:"*) : ;;
            *) export PATH="$HOME/.local/bin:$PATH" ;;
        esac
    fi
    PROF
    chmod 0644 /etc/profile.d/csi-localbin.sh
  - rm -f /etc/ssh/ssh_host_*_key /etc/ssh/ssh_host_*_key.pub
  - ': > /etc/machine-id'
  - rm -f /var/lib/dbus/machine-id
  - rm -rf /var/lib/cloud/instances /var/lib/cloud/data /var/lib/cloud/sem
  - apt-get clean
  - rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
  - fstrim -av || true

final_message: "csi ubuntu-base baked in $UPTIME seconds — powering off"

power_state:
  mode: poweroff
  message: "csi build complete"
  timeout: 600
  condition: true
